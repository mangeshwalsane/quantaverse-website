// ══════════════════════════════════════════
// 8. QUANTUM CANVAS — 60fps particle constellation
// ══════════════════════════════════════════
function initParticles() {
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  let W = 0, H = 0;
  let mouse = { x: -999, y: -999 };
  let easterActive = false;
  let easterParticles: { x: number; y: number; tx: number; ty: number; }[] = [];
  let animId = 0;

  const PARTICLE_COUNT = 90;
  const MAX_DIST = 130;
  const GOLD = 'rgba(201,169,110,';
  const TERRA = 'rgba(196,113,74,';

  interface Particle {
    x: number; y: number;
    vx: number; vy: number;
    size: number; alpha: number;
    baseX: number; baseY: number;
  }

  let particles: Particle[] = [];

  function resize() {
    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width  = W;
    canvas.height = H;
    // Rebuild static glows
    drawGlows();
  }

  function drawGlows() {
    const g1 = ctx.createRadialGradient(W*0.12, H*0.88, 0, W*0.12, H*0.88, W*0.55);
    g1.addColorStop(0, 'rgba(201,169,110,0.07)');
    g1.addColorStop(1, 'transparent');
    const g2 = ctx.createRadialGradient(W*0.85, H*0.2, 0, W*0.85, H*0.2, W*0.4);
    g2.addColorStop(0, 'rgba(196,113,74,0.04)');
    g2.addColorStop(1, 'transparent');
    return [g1, g2];
  }

  function spawnParticles() {
    particles = Array.from({ length: PARTICLE_COUNT }, () => {
      const x = Math.random() * W;
      const y = Math.random() * H;
      return {
        x, y, vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.4,
        size: Math.random() * 1.8 + 0.4, alpha: Math.random() * 0.5 + 0.1,
        baseX: x, baseY: y
      };
    });
  }

  // Easter egg: 'Q'/'V' assembles Quantaverse nested-diamond wireframe
  // Outer diamond, inner diamond, centre dot — mirrors the logo mark
  const LOGO_POINTS: [number, number][] = [];
  // Outer diamond (16 pts)
  for (let i = 0; i < 16; i++) {
    const a = (i / 16) * Math.PI * 2 - Math.PI / 4;
    const r = Math.abs(Math.cos(a)) + Math.abs(Math.sin(a)); // L1 norm → diamond
    LOGO_POINTS.push([Math.cos(a) / r, Math.sin(a) / r]);
  }
  // Inner diamond (12 pts at 62% scale)
  for (let i = 0; i < 12; i++) {
    const a = (i / 12) * Math.PI * 2 - Math.PI / 4;
    const r = Math.abs(Math.cos(a)) + Math.abs(Math.sin(a));
    LOGO_POINTS.push([Math.cos(a) / r * 0.62, Math.sin(a) / r * 0.62]);
  }
  // Centre cluster (remaining particles)
  while (LOGO_POINTS.length < PARTICLE_COUNT) {
    const a = Math.random() * Math.PI * 2;
    LOGO_POINTS.push([Math.cos(a) * 0.12, Math.sin(a) * 0.12]);
  }

  // Easter rotation state
  let easterAngle = 0;
  let easterTargetAngle = 0;
  let easterRotating = false; // true only after formation is assembled
  const formedX: number[] = [];
  const formedY: number[] = [];

  function buildEaster() {
    easterActive = true;
    easterRotating = false;
    easterAngle = 0;
    easterTargetAngle = 0;
    particles.forEach(p => gsap.killTweensOf(p));

    const cx2 = W * 0.5, cy2 = H * 0.5;
    const scale = Math.min(W, H) * 0.3;

    particles.forEach((p, i) => {
      const [lx, ly] = LOGO_POINTS[i % LOGO_POINTS.length];
      const fx = lx * scale + (Math.random() - 0.5) * 8;
      const fy = ly * scale + (Math.random() - 0.5) * 8;
      formedX[i] = fx;
      formedY[i] = fy;
      gsap.to(p, { x: cx2 + fx, y: cy2 + fy, duration: 1.1, ease: 'power3.out', delay: i * 0.006 });
    });

    // After formation assembles, hand off to rotation
    setTimeout(() => { easterRotating = true; }, 1300);

    // Explode back out after hold period
    setTimeout(() => {
      easterRotating = false;
      particles.forEach(p => {
        gsap.killTweensOf(p);
        gsap.to(p, { x: p.baseX, y: p.baseY, duration: 1.6, ease: 'power2.inOut', onComplete() { easterActive = false; } });
      });
    }, 3600);
  }

  // Rotate the formation on every tick — only after GSAP assembles it
  function applyEasterRotation() {
    if (!easterRotating) return;
    // Mouse X mapped to ±0.8 rad rotation target
    const mx = mouse.x < 0 ? W / 2 : mouse.x;
    easterTargetAngle = ((mx / W) - 0.5) * 1.6;
    easterAngle += (easterTargetAngle - easterAngle) * 0.04; // smooth follow

    const cx2 = W * 0.5, cy2 = H * 0.5;
    const cos = Math.cos(easterAngle), sin = Math.sin(easterAngle);
    particles.forEach((p, i) => {
      const fx = formedX[i] ?? 0, fy = formedY[i] ?? 0;
      p.x = cx2 + fx * cos - fy * sin;
      p.y = cy2 + fx * sin + fy * cos;
    });
  }

  window.addEventListener('keydown', (e) => {
    if ((e.key === 'q' || e.key === 'Q' || e.key === 'v' || e.key === 'V') && !easterActive) {
      buildEaster();
    }
  });

  canvas.addEventListener('mousemove', (e) => {
    const r = canvas.getBoundingClientRect();
    mouse.x = e.clientX - r.left;
    mouse.y = e.clientY - r.top;
  });
  canvas.addEventListener('mouseleave', () => { mouse.x = -999; mouse.y = -999; });

  function tick() {
    ctx.clearRect(0, 0, W, H);

    // Radial glows
    const glows = drawGlows();
    glows.forEach(g => { ctx.fillStyle = g; ctx.fillRect(0, 0, W, H); });

    // Apply mouse-driven rotation when easter formation is held
    applyEasterRotation();

    // Update & draw particles
    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];

      if (!easterActive) {
        // Gentle drift
        p.x += p.vx;
        p.y += p.vy;

        // Soft mouse gravity — attract within 180px
        const mdx = mouse.x - p.x;
        const mdy = mouse.y - p.y;
        const mdist = Math.sqrt(mdx*mdx + mdy*mdy);
        if (mdist < 180 && mdist > 0.1) {
          const force = (180 - mdist) / 180;
          p.vx += mdx / mdist * force * 0.055;
          p.vy += mdy / mdist * force * 0.055;
        }

        // Speed cap + drag
        const spd = Math.sqrt(p.vx*p.vx + p.vy*p.vy);
        if (spd > 2.5) { p.vx = p.vx / spd * 2.5; p.vy = p.vy / spd * 2.5; }
        p.vx *= 0.982;
        p.vy *= 0.982;

        // Wrap edges
        if (p.x < -10) p.x = W + 10; if (p.x > W + 10) p.x = -10;
        if (p.y < -10) p.y = H + 10; if (p.y > H + 10) p.y = -10;
      }
      // When easterActive, rotation override handles positions

      // Draw dot
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = GOLD + p.alpha + ')';
      ctx.fill();
    }

    // Constellation lines
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const d = Math.sqrt(dx*dx + dy*dy);
        if (d < MAX_DIST) {
          const alpha = (1 - d / MAX_DIST) * 0.15;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.strokeStyle = GOLD + alpha + ')';
          ctx.lineWidth = 0.6;
          ctx.stroke();
        }
      }
    }

    animId = requestAnimationFrame(tick);
  }

  function init() {
    resize();
    spawnParticles();
    tick();
  }

  let resizeTimer = 0;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => { cancelAnimationFrame(animId); init(); }, 200);
  }, { passive: true });

  init();
}

