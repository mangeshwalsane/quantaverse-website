---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Quantaverse Labs Pvt Ltd builds mobile apps, SaaS platforms, booking systems, AI tools, and custom digital infrastructure for businesses. Build once. Automate forever." />
  <meta property="og:title" content="Quantaverse Labs — We design, build, and automate digital businesses." />
  <meta property="og:description" content="Custom mobile apps, SaaS, booking systems, AI tools. Build once. Automate forever." />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#1C1917" />
  <title>Quantaverse Labs — We design, build, and automate digital businesses.</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<div class="grain" aria-hidden="true"></div>

<!-- ══════════════ NAV ══════════════ -->
<nav id="nav" class="site-nav">
  <div class="nav-inner">
    <a href="/" class="flex-shrink-0">
      <svg width="160" height="44" viewBox="0 0 160 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(0,2)">
          <rect x="2" y="9" width="18" height="18" rx="1.2" stroke="#C9A96E" stroke-width="1.1" transform="rotate(45 11 18)" fill="none"/>
          <rect x="5.5" y="12.5" width="11" height="11" rx="0.8" stroke="#C9A96E" stroke-width="0.7" opacity="0.4" transform="rotate(45 11 18)" fill="none"/>
          <rect x="8" y="15" width="6" height="6" rx="0.4" fill="#C9A96E" opacity="0.85" transform="rotate(45 11 18)"/>
        </g>
        <text x="35" y="19" font-family="'DM Sans',sans-serif" font-size="11" font-weight="600" letter-spacing="2.5" fill="#F5EFE4">QUANTAVERSE</text>
        <text x="35" y="34" font-family="'DM Sans',sans-serif" font-size="8.5" font-weight="300" letter-spacing="4.5" fill="#C9A96E">LABS  PVT  LTD</text>
      </svg>
    </a>
    <div class="nav-links">
      <a href="#services" class="nav-link">Services</a>
      <a href="#work"     class="nav-link">Work</a>
      <a href="#about"    class="nav-link">About</a>
      <a href="#contact"  class="btn-cta">Start a Project</a>
    </div>
    <button id="mobile-menu-btn" class="mobile-hamburger" aria-label="Menu">
      <svg width="24" height="20" viewBox="0 0 24 20" fill="none">
        <line x1="0" y1="3"  x2="24" y2="3"  stroke="#F5EFE4" stroke-width="1.5"/>
        <line x1="0" y1="10" x2="18" y2="10" stroke="#C9A96E" stroke-width="1.5"/>
        <line x1="0" y1="17" x2="24" y2="17" stroke="#F5EFE4" stroke-width="1.5"/>
      </svg>
    </button>
  </div>
</nav>

<div id="mobile-menu" class="mobile-menu-overlay">
  <button id="mobile-close" class="mobile-close-btn" aria-label="Close">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <path d="M6 6L18 18M6 18L18 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
  <a href="#services" class="mobile-nav-link">Services</a>
  <a href="#work"     class="mobile-nav-link">Work</a>
  <a href="#about"    class="mobile-nav-link">About</a>
  <a href="#contact"  class="mobile-nav-link">Contact</a>
</div>


<!-- ══════════════ HERO ══════════════ -->
<section id="hero" class="hero-section">
  <canvas id="hero-canvas"></canvas>
  <div class="hero-glow-1"></div>
  <div class="hero-glow-2"></div>

  <div class="hero-content">
    <div class="hero-inner">
      <div class="eyebrow reveal" data-delay="0">
        <div class="eyebrow-line"></div>
        <span>Digital Infrastructure Studio</span>
      </div>
      <h1 class="hero-headline reveal" data-delay="0.1">
        We design, build,<br/>
        and <em>automate</em><br/>
        digital businesses.
      </h1>
      <p class="hero-sub reveal" data-delay="0.22">
        From fitness marketplaces and mobile apps to booking engines, SaaS platforms, and AI-powered workflows — we create software that removes manual operations and scales efficiently.
      </p>
      <div class="hero-ctas reveal" data-delay="0.34">
        <a href="#contact" class="btn-primary">
          Start a Project
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        </a>
        <a href="#work" class="btn-outline">See Our Work</a>
      </div>
    </div>

    <div class="scroll-indicator reveal" data-delay="0.5">
      <div class="scroll-track"><div class="scroll-thumb"></div></div>
      <span class="scroll-label">Scroll</span>
    </div>
  </div>

  <div class="hero-stats-bar">
    <div class="stat-item reveal" data-delay="0">
      <p class="stat-num" data-counter="15" data-suffix=" days">15</p>
      <p class="stat-label">Days to Live</p>
    </div>
    <div class="stat-item reveal" data-delay="0.1">
      <p class="stat-num" data-counter="3" data-suffix="+">3+</p>
      <p class="stat-label">Products Shipped</p>
    </div>
    <div class="stat-item reveal" data-delay="0.2">
      <p class="stat-num">100%</p>
      <p class="stat-label">Code Ownership</p>
    </div>
    <div class="stat-item reveal" data-delay="0.3">
      <p class="stat-num">₹0</p>
      <p class="stat-label">Platform Lock-in</p>
    </div>
  </div>
</section>


<!-- ══════════════ SERVICES ══════════════ -->
<section id="services" class="section-wrap">
  <div class="container">
    <div class="section-header">
      <div>
        <div class="eyebrow reveal" data-delay="0"><div class="eyebrow-line"></div><span>What We Do</span></div>
        <h2 class="section-title reveal" data-delay="0.08">
          Full-spectrum digital<br/><em>infrastructure</em>
        </h2>
      </div>
      <p class="section-sub reveal" data-delay="0.16">
        We don't hand you a template. Every product is engineered from scratch — built to work autonomously so you can focus on running your business.
      </p>
    </div>

    <div class="services-grid">
      <div class="service-card reveal" data-delay="0">
        <div class="service-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="3" y="2" width="14" height="16" rx="1.5" stroke="#C9A96E" stroke-width="1.2"/>
            <rect x="6" y="6" width="8" height="1" rx="0.5" fill="#C9A96E" opacity="0.6"/>
            <rect x="6" y="9" width="6" height="1" rx="0.5" fill="#C9A96E" opacity="0.4"/>
            <circle cx="10" cy="13.5" r="1.5" stroke="#C9A96E" stroke-width="0.9"/>
          </svg>
        </div>
        <p class="service-num">01</p>
        <h3 class="service-title">Mobile Apps</h3>
        <p class="service-desc">iOS and Android apps built with Flutter — one codebase, two stores. From consumer marketplaces to B2B tools, we ship production-grade apps with real backend integrations.</p>
        <div class="tag-row"><span class="tag">Flutter</span><span class="tag">iOS</span><span class="tag">Android</span></div>
      </div>

      <div class="service-card reveal" data-delay="0.05">
        <div class="service-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="2" y="2" width="16" height="16" rx="1.5" stroke="#C9A96E" stroke-width="1.2"/>
            <path d="M2 7H18" stroke="#C9A96E" stroke-width="0.8" opacity="0.4"/>
            <circle cx="5" cy="4.5" r="0.8" fill="#C9A96E" opacity="0.6"/>
            <circle cx="8" cy="4.5" r="0.8" fill="#C9A96E" opacity="0.4"/>
            <path d="M6 11L8.5 13.5L14 9" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="service-num">02</p>
        <h3 class="service-title">Booking & Payment Platforms</h3>
        <p class="service-desc">End-to-end booking systems with real-time availability, Razorpay/Stripe payments, automated confirmations, and calendar sync. No manual follow-ups.</p>
        <div class="tag-row"><span class="tag">Razorpay</span><span class="tag">Calendar</span><span class="tag">Webhooks</span></div>
      </div>

      <div class="service-card reveal" data-delay="0.1">
        <div class="service-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="10" r="7.5" stroke="#C9A96E" stroke-width="1.2"/>
            <path d="M10 6V10.5L13 12" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="service-num">03</p>
        <h3 class="service-title">SaaS Platforms</h3>
        <p class="service-desc">Multi-tenant SaaS products with subscription billing, role-based access, admin dashboards, and analytics. Built to scale from 10 to 10,000 users without re-architecting.</p>
        <div class="tag-row"><span class="tag">Spring Boot</span><span class="tag">PostgreSQL</span><span class="tag">AWS</span></div>
      </div>

      <div class="service-card reveal" data-delay="0.15">
        <div class="service-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 14L7 9L10.5 12L14 7L17 10" stroke="#C9A96E" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="2" y="2" width="16" height="16" rx="1.5" stroke="#C9A96E" stroke-width="1" opacity="0.3"/>
          </svg>
        </div>
        <p class="service-num">04</p>
        <h3 class="service-title">AI Tools & Automation</h3>
        <p class="service-desc">Intelligent workflows powered by Claude, GPT, and custom ML pipelines. Automate customer support, content generation, document processing, and operational decisions.</p>
        <div class="tag-row"><span class="tag">Claude API</span><span class="tag">Automation</span><span class="tag">Workflows</span></div>
      </div>

      <div class="service-card reveal" data-delay="0.2">
        <div class="service-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="2" y="5" width="16" height="11" rx="1.5" stroke="#C9A96E" stroke-width="1.2"/>
            <path d="M2 8H18" stroke="#C9A96E" stroke-width="0.8" opacity="0.4"/>
            <circle cx="5" cy="6.5" r="0.7" fill="#C9A96E" opacity="0.6"/>
            <circle cx="7.5" cy="6.5" r="0.7" fill="#C9A96E" opacity="0.4"/>
            <rect x="5" y="11" width="5" height="1" rx="0.5" fill="#C9A96E" opacity="0.5"/>
            <rect x="5" y="13.5" width="3" height="1" rx="0.5" fill="#C9A96E" opacity="0.3"/>
          </svg>
        </div>
        <p class="service-num">05</p>
        <h3 class="service-title">Business Websites</h3>
        <p class="service-desc">Fast, mobile-first business websites with WhatsApp booking, Google Maps integration, and near-zero operating costs. Live in 12 days. You own everything.</p>
        <div class="tag-row"><span class="tag">Astro</span><span class="tag">Netlify</span><span class="tag">WhatsApp</span></div>
      </div>

      <div class="service-card reveal" data-delay="0.25">
        <div class="service-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M7 4L4 10L7 16" stroke="#C9A96E" stroke-width="1.3" stroke-linecap="round"/>
            <path d="M13 4L16 10L13 16" stroke="#C9A96E" stroke-width="1.3" stroke-linecap="round"/>
            <path d="M9.5 3L10.5 17" stroke="#C9A96E" stroke-width="0.8" opacity="0.4" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="service-num">06</p>
        <h3 class="service-title">Custom Software</h3>
        <p class="service-desc">Bespoke backend systems, REST APIs, admin panels, and data pipelines tailored to your exact process. If your business has a workflow, we can automate it.</p>
        <div class="tag-row"><span class="tag">Java</span><span class="tag">Node.js</span><span class="tag">APIs</span></div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════ HOW WE WORK ══════════════ -->
<section id="process" class="section-wrap section-border">
  <div class="container">
    <div class="process-grid">
      <div class="process-left">
        <div class="eyebrow reveal" data-delay="0"><div class="eyebrow-line"></div><span>How We Work</span></div>
        <h2 class="section-title reveal" data-delay="0.08">
          From brief to<br/><em>live product</em><br/>in 15 days.
        </h2>
        <p class="body-text reveal" data-delay="0.16">
          No discovery phases that stretch into months. No surprise billing. We move fast because we've built systems like yours before.
        </p>
        <a href="#contact" class="btn-primary reveal" data-delay="0.24">
          Let's Talk
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        </a>
      </div>

      <div class="process-steps">
        <div class="process-vline"></div>

        <div class="process-step reveal" data-delay="0">
          <div class="step-dot"><span>01</span></div>
          <div class="step-body">
            <p class="step-phase">Days 1–3</p>
            <h3 class="step-title">Discover & Design</h3>
            <p class="step-desc">We map your full workflow, decide the right stack, and finalise UI direction. You sign off on wireframes before a single line of code is written.</p>
          </div>
        </div>

        <div class="process-step reveal" data-delay="0.1">
          <div class="step-dot"><span>02</span></div>
          <div class="step-body">
            <p class="step-phase">Days 4–12</p>
            <h3 class="step-title">Build & Integrate</h3>
            <p class="step-desc">Full-stack development: frontend, backend, payments, automations, email flows. Daily progress updates. You watch it being built.</p>
          </div>
        </div>

        <div class="process-step reveal" data-delay="0.2">
          <div class="step-dot"><span>03</span></div>
          <div class="step-body">
            <p class="step-phase">Days 13–15</p>
            <h3 class="step-title">Deploy & Hand Off</h3>
            <p class="step-desc">We deploy to your domain, configure DNS, and hand over full source code and credentials. You own everything — no lock-in, no monthly fee.</p>
          </div>
        </div>

        <div class="process-step reveal" data-delay="0.3" style="opacity:0.4">
          <div class="step-dot step-dot-dim"><span>∞</span></div>
          <div class="step-body">
            <p class="step-phase">Post-Launch</p>
            <h3 class="step-title" style="color:rgba(245,239,228,0.35)">Runs Autonomously</h3>
            <p class="step-desc" style="color:rgba(245,239,228,0.18)">Your platform operates 24/7 without you touching it. Build once. Automate forever.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════ STATS ══════════════ -->
<section id="stats" class="section-wrap section-border">
  <div class="container">
    <div class="stats-header">
      <div class="eyebrow eyebrow-center reveal" data-delay="0">
        <div class="eyebrow-line"></div><span>By the Numbers</span><div class="eyebrow-line"></div>
      </div>
      <h2 class="section-title text-center reveal" data-delay="0.08">Built for <em>efficiency</em></h2>
    </div>

    <div class="stats-counters reveal" data-delay="0">
      <div class="counter-item">
        <p class="counter-num" data-counter="15" data-suffix=" days">15 days</p>
        <p class="counter-label">Average delivery</p>
      </div>
      <div class="counter-item">
        <p class="counter-num" data-counter="100" data-suffix="%">100%</p>
        <p class="counter-label">Code ownership transferred</p>
      </div>
      <div class="counter-item">
        <p class="counter-num" data-counter="3" data-suffix="+">3+</p>
        <p class="counter-label">Products in production</p>
      </div>
      <div class="counter-item">
        <p class="counter-num" data-counter="6" data-suffix="">6</p>
        <p class="counter-label">Service verticals</p>
      </div>
    </div>

    <div class="charts-grid">
      <!-- Donut -->
      <div class="chart-card reveal" data-delay="0">
        <p class="chart-eyebrow">Technology Split</p>
        <p class="chart-title">How we build</p>
        <div class="chart-donut-wrap">
          <canvas id="chart-tech" width="180" height="180"></canvas>
          <div class="donut-center">
            <p class="donut-pct">30%</p>
            <p class="donut-lbl">Mobile</p>
          </div>
        </div>
        <div class="chart-legend">
          <div class="legend-row"><span class="legend-dot" style="background:#C9A96E"></span><span>Mobile (Flutter)</span><span class="ml-auto">30%</span></div>
          <div class="legend-row"><span class="legend-dot" style="background:#C4714A"></span><span>Backend APIs</span><span class="ml-auto">25%</span></div>
          <div class="legend-row"><span class="legend-dot" style="background:#8C7B6B"></span><span>Web Platforms</span><span class="ml-auto">25%</span></div>
          <div class="legend-row"><span class="legend-dot" style="background:#4A6741"></span><span>AI & Automation</span><span class="ml-auto">20%</span></div>
        </div>
      </div>

      <!-- Bar -->
      <div class="chart-card reveal" data-delay="0.08">
        <p class="chart-eyebrow">Delivery Speed</p>
        <p class="chart-title">Us vs. industry average</p>
        <canvas id="chart-speed" width="300" height="220"></canvas>
      </div>

      <!-- Radar -->
      <div class="chart-card reveal" data-delay="0.16">
        <p class="chart-eyebrow">Capability Depth</p>
        <p class="chart-title">Core strengths</p>
        <div class="radar-wrap">
          <canvas id="chart-radar" width="220" height="220"></canvas>
        </div>
      </div>

      <!-- Line -->
      <div class="chart-card chart-card-wide reveal" data-delay="0.24">
        <p class="chart-eyebrow">Project Growth</p>
        <p class="chart-title">Clients & products over time</p>
        <canvas id="chart-line" width="600" height="180"></canvas>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════ WORK ══════════════ -->
<section id="work" class="section-wrap section-border">
  <div class="container">
    <div class="section-header">
      <div>
        <div class="eyebrow reveal" data-delay="0"><div class="eyebrow-line"></div><span>Our Work</span></div>
        <h2 class="section-title reveal" data-delay="0.08">Products we've<br/><em>shipped</em></h2>
      </div>
      <p class="section-sub reveal" data-delay="0.16">Every project starts as a business problem. It ends as a platform that runs without you.</p>
    </div>

    <div class="work-grid">
      <div class="work-card work-card-featured reveal" data-delay="0">
        <div class="work-card-inner">
          <div class="work-card-info">
            <div class="work-badges">
              <span class="badge-gold">Own Product</span>
              <span class="badge-pulse">
                <span class="pulse-dot" style="background:#C4714A"></span>
                Coming to App Store & Google Play
              </span>
            </div>
            <h3 class="work-title">Fitnity</h3>
            <p class="work-desc">India's next-generation fitness and sports marketplace. Connects users with gyms, yoga studios, swimming centres, zumba studios, and sports facilities through one unified platform — with subscriptions, live bookings, QR check-ins, and coach sessions.</p>
            <div class="tag-row">
              <span class="tag">Flutter</span><span class="tag">Spring Boot 4</span><span class="tag">PostgreSQL</span><span class="tag">AWS</span><span class="tag">Razorpay</span>
            </div>
            <a href="https://fitnity.in" target="_blank" rel="noopener" class="btn-outline work-btn">
              Visit fitnity.in
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            </a>
          </div>
          <div class="work-card-visual">
            <div class="fitnity-bg-glow"></div>
            <div class="fitnity-wordmark">fitnity</div>
            <div class="fitnity-modules">
              <span class="fmod">Gym</span><span class="fmod">Yoga</span><span class="fmod">Swimming</span><span class="fmod">Zumba</span><span class="fmod">Sports</span>
            </div>
            <p class="fitnity-sub">5 Modules · iOS & Android</p>
          </div>
        </div>
      </div>

      <div class="work-card work-card-sm reveal" data-delay="0.1">
        <div class="work-badges mb-5">
          <span class="badge-muted">Client Work</span>
          <span class="badge-pulse badge-green"><span class="pulse-dot" style="background:#4A9A6A"></span>In Delivery</span>
        </div>
        <h3 class="work-title-sm">KAARA Studio</h3>
        <p class="work-desc">Full booking platform for a luxury co-working and yoga studio in Surat. Real-time availability, Razorpay payments, Google Calendar sync, recurring plans, automated confirmation emails.</p>
        <div class="tag-row mt-6">
          <span class="tag">Astro</span><span class="tag">Netlify</span><span class="tag">Google Calendar</span><span class="tag">Razorpay</span>
        </div>
      </div>

      <div class="work-card work-card-sm reveal" data-delay="0.2">
        <div class="work-badges mb-5">
          <span class="badge-muted">Client Work</span>
          <span class="badge-pulse badge-green"><span class="pulse-dot" style="background:#4A9A6A"></span>In Delivery</span>
        </div>
        <h3 class="work-title-sm">City Smile Dental</h3>
        <p class="work-desc">Mobile-first digital presence for a 14-year-old dental clinic in Vadodara. WhatsApp booking, Google Maps integration, before/after gallery — fully owned by the clinic, zero platform fees.</p>
        <div class="tag-row mt-6">
          <span class="tag">Static</span><span class="tag">WhatsApp</span><span class="tag">Netlify</span><span class="tag">12 Days</span>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════ ABOUT ══════════════ -->
<section id="about" class="section-wrap section-border">
  <div class="container">
    <div class="about-grid">
      <div>
        <div class="eyebrow reveal" data-delay="0"><div class="eyebrow-line"></div><span>About</span></div>
        <h2 class="section-title reveal" data-delay="0.08">We are<br/><em>Quantaverse Labs</em></h2>
        <div class="about-body reveal" data-delay="0.16">
          <p>Quantaverse Labs Private Limited is a digital product company based in India. We design, build, and automate digital businesses — from consumer-facing marketplaces to operational back-office systems.</p>
          <p>We operate on two tracks: our own products, where we build and own the IP, and client infrastructure, where we build digital systems for businesses that want to operate more efficiently.</p>
