// 13. 15-DAY TIMELINE — staggered scroll reveal
// ══════════════════════════════════════════
(function() {
  const tlFill = document.getElementById('tl-fill') as SVGLineElement | null;
  const nodes  = document.querySelectorAll<HTMLElement>('.tl-node');
  const tlCol  = document.querySelector('.process-timeline-col') as HTMLElement | null;
  if (!tlFill || !nodes.length || !tlCol) return;

  const TOTAL = nodes.length;

  // Animate SVG path drawing + staggered node light-up on scroll into view
  ScrollTrigger.create({
    trigger: tlCol,
    start: 'top 75%',
    end: 'bottom 25%',
    scrub: 0.8,
    onUpdate(self) {
      const p = self.progress;
      // Draw path top → bottom
      tlFill.style.strokeDashoffset = String(560 * (1 - p));
      // Light nodes sequentially
      nodes.forEach((node, i) => {
        const threshold = i / (TOTAL - 1);
        node.classList.toggle('lit', p >= threshold - 0.04);
      });
    },
    onEnter() {
      // Ensure first node lights immediately
      nodes[0]?.classList.add('lit');
    }
  });
})();

// ══════════════════════════════════════════
// 14. STATS SECTION — 5-animation cinematic sequence
// ══════════════════════════════════════════
ScrollTrigger.create({
  trigger: '#stats', start: 'top 72%', once: true,
  onEnter() {

    // ── 14A. Vertical + horizontal border line reveals ──────────────────
    // Horizontal lines sweep in from left simultaneously
    gsap.to(['#shl-top','#shl-bot'], {
      scaleX: 1, duration: 0.9, ease: 'power3.inOut', stagger: 0.08
    });
    // Vertical lines grow from center, staggered left-to-right
    gsap.to(['#svl-2','#svl-1','#svl-3'], {
      scaleY: 1, duration: 1.1, ease: 'power3.inOut', stagger: 0.12, delay: 0.1
    });

    // ── 14B. Counter — fast-to-slow already wired in section 12 ─────────
    // (expo.out counters fire from ScrollTrigger on '#stats-grid')

    // ── 14C. SVG Donut — stroke-dashoffset reveal + legend stagger ──────
    // Circumference = 2π×58 ≈ 364.4
    // Each segment needs its own rotation offset so they tile around the ring
    // Mobile: offset=364.4 → 0  (starts at top)
    // Backend: offset=364.4-109.3=255.1 → 255.1 (starts after Mobile arc)
    // Web:     offset=364.4-109.3-91.1=164.0 → 164.0
    // AI:      offset=364.4-109.3-91.1-91.1=72.9 → 72.9
    const C = 364.4;
    const segments = [
      { id: 'ds-mobile',  arc: 109.3, finalOffset: 0,         pct: 30 },
      { id: 'ds-backend', arc: 91.1,  finalOffset: C-109.3,   pct: 25 },
      { id: 'ds-web',     arc: 91.1,  finalOffset: C-200.4,   pct: 25 },
      { id: 'ds-ai',      arc: 72.9,  finalOffset: C-291.5,   pct: 20 },
    ];
    segments.forEach((seg, i) => {
      const el = document.getElementById(seg.id) as SVGCircleElement | null;
      if (!el) return;
      // Set dasharray so only this segment is visible; offset controls how much is drawn
      el.setAttribute('stroke-dasharray', `${seg.arc} ${C}`);
      el.setAttribute('stroke-dashoffset', String(seg.arc)); // fully hidden
      gsap.to(el, {
        attr: { 'stroke-dashoffset': seg.finalOffset },
        duration: 1.4,
        delay: 0.3 + i * 0.18,
        ease: 'power3.inOut',
      });
    });
    // Counter inside donut: 0 → 30
    const donutPct = document.getElementById('donut-pct');
    if (donutPct) {
      const o = { v: 0 };
      gsap.to(o, { v: 30, duration: 1.6, delay: 0.4, ease: 'power3.out',
        onUpdate() { donutPct.textContent = Math.round(o.v) + '%'; }
      });
    }
    // Legend rows stagger in after segments draw
    const legendRows = document.querySelectorAll<HTMLElement>('#donut-legend .legend-row');
    gsap.to(legendRows, {
      opacity: 1, x: 0, duration: 0.5, stagger: 0.1, delay: 1.1,
      ease: 'power2.out', clearProps: 'transform'
    });

    // ── 14D. Bar chart — GSAP-driven data injection (gold fast, grey slow) ──
    const ctxB = (document.getElementById('chart-speed') as HTMLCanvasElement)?.getContext('2d');
    if (ctxB) {
      const qvFinal  = [12, 15, 20, 25];   // Quantaverse (gold)
      const indFinal = [30, 60, 90, 120];  // Industry (grey)
      const progress = { qv: 0, ind: 0 };

      const barChart = new Chart(ctxB, {
        type: 'bar',
        data: {
          labels: ['Static Site','Booking','Mobile App','SaaS'],
          datasets: [
            { label: 'Quantaverse', data: [0,0,0,0],
              backgroundColor: 'rgba(201,169,110,0.85)', borderColor: '#C9A96E',
              borderWidth: 1, borderRadius: 6, borderSkipped: false },
            { label: 'Industry Avg', data: [0,0,0,0],
              backgroundColor: 'rgba(255,255,255,0.07)', borderColor: 'rgba(255,255,255,0.15)',
              borderWidth: 1, borderRadius: 6, borderSkipped: false }
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          plugins: {
            legend: { labels: { color:'rgba(245,239,228,0.36)', font:{ family:'DM Sans', size:11 }, boxWidth:10, padding:16 } },
            tooltip: { backgroundColor:'#1C1814', titleColor:'#F5EFE4', bodyColor:'#8C7B6B',
              borderColor:'rgba(201,169,110,0.2)', borderWidth:1,
              callbacks: { label:(ctx:any) => ` ${ctx.dataset.label}: ${ctx.parsed.y} days` } }
          },
          scales: {
            x: { ticks:{ color:'rgba(245,239,228,0.3)', font:{ family:'DM Sans', size:10 } },
                 grid:{ color:'rgba(245,239,228,0.04)' }, border:{ color:'rgba(245,239,228,0.08)' } },
            y: { ticks:{ color:'rgba(245,239,228,0.3)', font:{ family:'DM Sans', size:10 }, callback:(v:any)=>v+'d' },
                 grid:{ color:'rgba(245,239,228,0.04)' }, border:{ color:'rgba(245,239,228,0.08)' } }
          }
        }
      });

      // Gold (Quantaverse) bars: fast — expo.out, 0.9s
      gsap.to(progress, {
        qv: 1, duration: 0.9, ease: 'expo.out',
        onUpdate() {
          barChart.data.datasets[0].data = qvFinal.map(v => v * progress.qv);
          barChart.update('none');
        }
      });
      // Industry bars: slow heavy — power1.out, 2.2s with stagger feel via delay
      gsap.to(progress, {
        ind: 1, duration: 2.2, delay: 0.15, ease: 'power1.out',
        onUpdate() {
          barChart.data.datasets[1].data = indFinal.map(v => v * progress.ind);
          barChart.update('none');
        }
      });
    }

    // ── 14E. SVG Radar — polygon expansion from center ──────────────────
    // 6 axes at 0°,60°,120°,180°,240°,300° (top = Engineering, clockwise)
    // Full-ring radius = 92px (110 center, outer ring tip at 18 → 110-18=92)
    // Scores: Engineering=95, Payments=90, Cloud=88, AI=82, UI/UX=85, Mobile=93
    const CX = 110, CY = 110, R_MAX = 92;
    const scores = [0.95, 0.90, 0.88, 0.82, 0.85, 0.93]; // normalised 0-1
    const angles = scores.map((_, i) => -Math.PI/2 + (i * Math.PI * 2) / 6);

    // Target points (full score)
    const targetPts: [number,number][] = scores.map((s, i) => [
      CX + Math.cos(angles[i]) * R_MAX * s,
      CY + Math.sin(angles[i]) * R_MAX * s
    ]);

    const poly   = document.getElementById('radar-poly') as SVGPolygonElement | null;
    const rPts   = Array.from({ length: 6 }, (_, i) => document.getElementById(`rp-${i}`) as SVGCircleElement | null);

    if (poly) {
      const prog = { t: 0 };
      gsap.to(prog, {
        t: 1, duration: 1.8, delay: 0.2, ease: 'power3.out',
        onUpdate() {
          const t = prog.t;
          const pts = targetPts.map(([tx, ty]) => [
            CX + (tx - CX) * t,
            CY + (ty - CY) * t
          ]);
          poly.setAttribute('points', pts.map(p => p.join(',')).join(' '));
          rPts.forEach((rp, i) => {
            if (!rp) return;
            rp.setAttribute('cx', String(pts[i][0]));
            rp.setAttribute('cy', String(pts[i][1]));
          });
        }
      });
    }

  } // onEnter
});

