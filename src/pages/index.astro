---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Quantaverse Labs Pvt Ltd builds mobile apps, SaaS platforms, booking systems, AI tools, and custom digital infrastructure for businesses. Build once. Automate forever." />
  <meta property="og:title" content="Quantaverse Labs — We design, build, and automate digital businesses." />
  <meta property="og:description" content="Custom mobile apps, SaaS, booking systems, AI tools. Build once. Automate forever." />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#0F0D0B" />
  <title>Quantaverse Labs — We design, build, and automate digital businesses.</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<div class="grain" aria-hidden="true"></div>

<!-- ══════════════ NAV ══════════════ -->
<nav id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <svg width="148" height="40" viewBox="0 0 160 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(0,2)">
          <rect x="2" y="9" width="18" height="18" rx="1.2" stroke="#C9A96E" stroke-width="1.1" transform="rotate(45 11 18)" fill="none"/>
          <rect x="5.5" y="12.5" width="11" height="11" rx="0.8" stroke="#C9A96E" stroke-width="0.7" opacity="0.4" transform="rotate(45 11 18)" fill="none"/>
          <rect x="8" y="15" width="6" height="6" rx="0.4" fill="#C9A96E" opacity="0.85" transform="rotate(45 11 18)"/>
        </g>
        <text x="35" y="19" font-family="'DM Sans',sans-serif" font-size="11" font-weight="600" letter-spacing="2.5" fill="#F5EFE4">QUANTAVERSE</text>
        <text x="35" y="34" font-family="'DM Sans',sans-serif" font-size="8.5" font-weight="300" letter-spacing="4.5" fill="#C9A96E">LABS  PVT  LTD</text>
      </svg>
    </a>
    <a href="#contact" class="nav-cta">Start a Project</a>
    <button id="mob-btn" class="mob-btn" aria-label="Menu">
      <span></span><span></span>
    </button>
  </div>
</nav>

<div id="mob-overlay" class="mob-overlay">
  <button id="mob-close" aria-label="Close">✕</button>
  <a href="#services" class="mob-link">Services</a>
  <a href="#work"     class="mob-link">Work</a>
  <a href="#about"    class="mob-link">About</a>
  <a href="#contact"  class="mob-link">Contact</a>
</div>


<!-- ══════════════ HERO ══════════════ -->
<section id="hero">
  <canvas id="hero-canvas"></canvas>

  <div class="hero-badge">
    <span class="hero-badge-dot"></span>
    Digital Infrastructure Studio
  </div>

  <div class="hero-text">
    <h1 class="hero-h1">
      We design,<br/>
      build, and<br/>
      <em>automate</em><br/>
      digital<br/>
      businesses.
    </h1>
    <div class="hero-bottom">
      <p class="hero-sub">From fitness marketplaces to booking engines, SaaS platforms, and AI workflows — software that removes manual operations.</p>
      <a href="#contact" class="hero-cta">
        Start a Project
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9H14M14 9L10 5M14 9L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </a>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="hero-scroll-line"></div>
    <span>scroll</span>
  </div>
</section>


<!-- ══════════════ MARQUEE ══════════════ -->
<div class="marquee-wrap">
  <div class="marquee-track">
    <span>Mobile Apps</span><span class="marquee-dot">✦</span>
    <span>SaaS Platforms</span><span class="marquee-dot">✦</span>
    <span>Booking Systems</span><span class="marquee-dot">✦</span>
    <span>AI Automation</span><span class="marquee-dot">✦</span>
    <span>Business Websites</span><span class="marquee-dot">✦</span>
    <span>Custom Software</span><span class="marquee-dot">✦</span>
    <span>Mobile Apps</span><span class="marquee-dot">✦</span>
    <span>SaaS Platforms</span><span class="marquee-dot">✦</span>
    <span>Booking Systems</span><span class="marquee-dot">✦</span>
    <span>AI Automation</span><span class="marquee-dot">✦</span>
    <span>Business Websites</span><span class="marquee-dot">✦</span>
    <span>Custom Software</span><span class="marquee-dot">✦</span>
  </div>
</div>


<!-- ══════════════ SERVICES ══════════════ -->
<section id="services" class="services-section">
  <div class="container">
    <div class="svc-header">
      <p class="section-label">What We Do</p>
      <h2 class="svc-h2">Six ways we build your<br/><em>digital infrastructure</em></h2>
    </div>

    <div class="svc-grid">

      <!-- Card 1 — tall, teal — Mobile Apps -->
      <div class="svc-card svc-tall" style="--bg:#0D3B35;--accent:#3ECFB2;--num-c:rgba(62,207,178,0.08)">
        <div class="svc-inner">
          <div class="svc-num">01</div>
          <div class="svc-body">
            <h3>Mobile Apps</h3>
            <p>iOS and Android apps built with Flutter — one codebase, two stores. We ship production-grade apps with real backend integrations.</p>
            <div class="svc-tags"><span>Flutter</span><span>iOS</span><span>Android</span><span>Firebase</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-circle" style="background:rgba(62,207,178,0.1)"></div>
      </div>

      <!-- Card 2 — wide, terracotta — Booking & Payments -->
      <div class="svc-card svc-wide" style="--bg:#3D1A12;--accent:#F07A4A;--num-c:rgba(240,122,74,0.08)">
        <div class="svc-inner">
          <div class="svc-num">02</div>
          <div class="svc-body">
            <h3>Booking & Payments</h3>
            <p>End-to-end booking systems with Razorpay, real-time availability, automated confirmations, and calendar sync. Zero manual work.</p>
            <div class="svc-tags"><span>Razorpay</span><span>Calendar</span><span>Webhooks</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-ring" style="border-color:rgba(240,122,74,0.15)"></div>
      </div>

      <!-- Card 3 — standard, navy blue — SaaS -->
      <div class="svc-card" style="--bg:#111836;--accent:#7B9EF0;--num-c:rgba(123,158,240,0.08)">
        <div class="svc-inner">
          <div class="svc-num">03</div>
          <div class="svc-body">
            <h3>SaaS Platforms</h3>
            <p>Multi-tenant SaaS with subscription billing, role-based access, and analytics. Scales from 10 to 10,000 users.</p>
            <div class="svc-tags"><span>Spring Boot</span><span>PostgreSQL</span><span>AWS</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-pill" style="background:rgba(123,158,240,0.08)"></div>
      </div>

      <!-- Card 4 — standard, purple — AI -->
      <div class="svc-card" style="--bg:#1E1130;--accent:#C47AE8;--num-c:rgba(196,122,232,0.08)">
        <div class="svc-inner">
          <div class="svc-num">04</div>
          <div class="svc-body">
            <h3>AI & Automation</h3>
            <p>Intelligent workflows powered by Claude and GPT. Automate support, content, documents, and operational decisions.</p>
            <div class="svc-tags"><span>Claude API</span><span>GPT</span><span>Pipelines</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-diamond" style="background:rgba(196,122,232,0.1)"></div>
      </div>

      <!-- Card 5 — wide, forest green — Websites -->
      <div class="svc-card svc-wide" style="--bg:#0F2E18;--accent:#4DC878;--num-c:rgba(77,200,120,0.08)">
        <div class="svc-inner">
          <div class="svc-num">05</div>
          <div class="svc-body">
            <h3>Business Websites</h3>
            <p>Fast, mobile-first websites with WhatsApp booking, Google Maps, and near-zero operating costs. Live in 12 days. You own everything.</p>
            <div class="svc-tags"><span>Astro</span><span>Netlify</span><span>WhatsApp</span><span>12 Days</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-square" style="background:rgba(77,200,120,0.08)"></div>
      </div>

      <!-- Card 6 — tall, amber — Custom Software -->
      <div class="svc-card svc-tall" style="--bg:#2E2206;--accent:#E8C84A;--num-c:rgba(232,200,74,0.08)">
        <div class="svc-inner">
          <div class="svc-num">06</div>
          <div class="svc-body">
            <h3>Custom Software</h3>
            <p>Bespoke backend systems, REST APIs, admin panels, and data pipelines. If your business has a workflow, we can automate it.</p>
            <div class="svc-tags"><span>Java</span><span>Node.js</span><span>APIs</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-circle" style="background:rgba(232,200,74,0.08)"></div>
      </div>

    </div>
  </div>
</section>


<!-- ══════════════ STATS ══════════════ -->
<section id="stats" class="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-big">
        <p class="stat-num" data-counter="15" data-suffix="">15</p>
        <p class="stat-unit">days</p>
        <p class="stat-desc">Average delivery from brief to live product</p>
      </div>
      <div class="stat-big">
        <p class="stat-num" data-counter="100" data-suffix="%">100%</p>
        <p class="stat-desc">Code ownership transferred — no lock-in, ever</p>
      </div>
      <div class="stat-big">
        <p class="stat-num" data-counter="3" data-suffix="+">3+</p>
        <p class="stat-desc">Products live in production and growing</p>
      </div>
      <div class="stat-big">
        <p class="stat-num" data-counter="6" data-suffix="">6</p>
        <p class="stat-desc">Service verticals across mobile, web, AI, and cloud</p>
      </div>
    </div>

    <div class="charts-row">
      <div class="chart-block">
        <p class="chart-label">Technology split</p>
        <div class="chart-donut-wrap">
          <canvas id="chart-tech"></canvas>
          <div class="donut-center"><p class="donut-pct">30%</p><p class="donut-lbl">Mobile</p></div>
        </div>
        <div class="chart-legend">
          <div class="legend-row"><span class="ld" style="background:#C9A96E"></span><span>Mobile</span><span class="lv">30%</span></div>
          <div class="legend-row"><span class="ld" style="background:#E8865A"></span><span>Backend</span><span class="lv">25%</span></div>
          <div class="legend-row"><span class="ld" style="background:#6B8AE8"></span><span>Web</span><span class="lv">25%</span></div>
          <div class="legend-row"><span class="ld" style="background:#B87AE8"></span><span>AI</span><span class="lv">20%</span></div>
        </div>
      </div>
      <div class="chart-block chart-block-wide">
        <p class="chart-label">Delivery speed — Quantaverse vs industry average (days)</p>
        <canvas id="chart-speed"></canvas>
      </div>
      <div class="chart-block">
        <p class="chart-label">Capability depth</p>
        <canvas id="chart-radar"></canvas>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════ HOW WE WORK (light section) ══════════════ -->
<section id="process" class="process-section">
  <div class="container">
    <div class="process-header">
      <p class="section-label section-label-dark">How We Work</p>
      <h2 class="process-h2">Brief to live product<br/>in <em>15 days.</em></h2>
      <p class="process-sub">No discovery phases that stretch into months. No surprise billing. We move fast because we've built systems like yours before.</p>
    </div>

    <div class="process-cards">
      <div class="process-card" style="--pc:#E8865A">
        <div class="pc-num">01</div>
        <div class="pc-body">
          <p class="pc-phase">Days 1–3</p>
          <h3 class="pc-title">Discover & Design</h3>
          <p class="pc-desc">We map your full workflow, decide the right stack, and finalise UI direction. You sign off on wireframes before a single line of code is written.</p>
        </div>
      </div>
      <div class="process-card" style="--pc:#6B8AE8">
        <div class="pc-num">02</div>
        <div class="pc-body">
          <p class="pc-phase">Days 4–12</p>
          <h3 class="pc-title">Build & Integrate</h3>
          <p class="pc-desc">Full-stack development: frontend, backend, payments, automations, email flows. Daily progress updates. You watch it being built.</p>
        </div>
      </div>
      <div class="process-card" style="--pc:#5EC87A">
        <div class="pc-num">03</div>
        <div class="pc-body">
          <p class="pc-phase">Days 13–15</p>
          <h3 class="pc-title">Deploy & Hand Off</h3>
          <p class="pc-desc">We deploy to your domain, configure DNS, and hand over full source code and credentials. You own everything — no lock-in, no monthly fee.</p>
        </div>
      </div>
      <div class="process-card process-card-dark">
        <div class="pc-num" style="color:#C9A96E">∞</div>
        <div class="pc-body">
          <p class="pc-phase" style="color:rgba(245,239,228,0.4)">Post-Launch</p>
          <h3 class="pc-title" style="color:#F5EFE4">Runs Autonomously</h3>
          <p class="pc-desc" style="color:rgba(245,239,228,0.35)">Your platform operates 24/7 without you touching it. Build once. Automate forever.</p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════ WORK ══════════════ -->
<section id="work" class="work-section">
  <div class="container">
    <div class="work-header">
      <p class="section-label">Our Work</p>
      <h2 class="work-h2">Products we've<br/><em>shipped</em></h2>
      <p class="work-sub">Every project starts as a business problem. It ends as a platform that runs without you.</p>
    </div>

    <div class="work-grid">
      <!-- Fitnity featured -->
      <div class="work-card work-card-featured">
        <div class="wc-info">
          <div class="wc-badges">
            <span class="badge-own">Own Product</span>
            <span class="badge-wip"><span class="pulse-dot" style="background:#E8865A"></span>In Development</span>
          </div>
          <h3 class="wc-title">Fitnity</h3>
          <p class="wc-desc">India's next-generation fitness and sports marketplace. Connects users with gyms, yoga studios, swimming centres, zumba studios, and sports facilities — subscriptions, live bookings, QR check-ins, coach sessions.</p>
          <div class="wc-tags">
            <span>Flutter</span><span>Spring Boot 4</span><span>PostgreSQL</span><span>AWS</span><span>Razorpay</span>
          </div>
          <p class="wc-coming">Launching soon at fitnity.in</p>
        </div>
        <div class="wc-visual">
          <div class="wc-glow"></div>
          <div class="wc-wordmark">fitnity</div>
          <div class="wc-modules">
            <span>Gym</span><span>Yoga</span><span>Swimming</span><span>Zumba</span><span>Sports</span>
          </div>
          <p class="wc-caption">5 Modules · iOS & Android</p>
        </div>
      </div>

      <div class="work-card work-card-sm" style="--wc:#1A4A47">
        <div class="wcs-top">
          <span class="badge-client">Client</span>
          <span class="badge-delivery"><span class="pulse-dot" style="background:#5EC87A"></span>In Delivery</span>
        </div>
        <h3 class="wcs-title">KAARA Studio</h3>
        <p class="wcs-desc">Full booking platform for a luxury co-working and yoga studio in Surat. Razorpay payments, Google Calendar sync, recurring plans, automated confirmations.</p>
        <div class="wcs-tags"><span>Astro</span><span>Razorpay</span><span>Google Cal</span></div>
      </div>

      <div class="work-card work-card-sm" style="--wc:#3D1F1A">
        <div class="wcs-top">
          <span class="badge-client">Client</span>
          <span class="badge-delivery"><span class="pulse-dot" style="background:#5EC87A"></span>In Delivery</span>
        </div>
        <h3 class="wcs-title">City Smile Dental</h3>
        <p class="wcs-desc">Mobile-first digital presence for a 14-year-old dental clinic in Vadodara. WhatsApp booking, Maps integration, before/after gallery — zero platform fees.</p>
        <div class="wcs-tags"><span>Static</span><span>WhatsApp</span><span>12 Days</span></div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════ ABOUT (light) ══════════════ -->
<section id="about" class="about-section">
  <div class="container">
    <div class="about-grid">
      <div class="about-left">
        <p class="section-label section-label-dark">About</p>
        <h2 class="about-h2">We are<br/><em>Quantaverse Labs</em></h2>
        <div class="about-body">
          <p>Quantaverse Labs Private Limited is a digital product company based in India. We design, build, and automate digital businesses — from consumer-facing marketplaces to operational back-office systems.</p>
          <p>We operate on two tracks: our own products, where we build and own the IP, and client infrastructure, where we build digital systems for businesses that want to operate more efficiently.</p>
          <p>No SaaS lock-in. No recurring agency fees. No middle-layer dependencies. We hand you working software and full ownership on day 15.</p>
        </div>
        <a href="#contact" class="about-cta">Let's build together →</a>
      </div>
      <div class="about-right">
        <div class="value-pill" style="--vp:#1A4A47;--vt:#5ECFB8">
          <div class="vp-icon">✓</div>
          <div><h4>100% Ownership</h4><p>Full source code, credentials, and infra access on day 15.</p></div>
        </div>
        <div class="value-pill" style="--vp:#3D1F1A;--vt:#E8865A">
          <div class="vp-icon">⚡</div>
          <div><h4>15-Day Delivery</h4><p>Production-ready — not because we rush, but because we've done it before.</p></div>
        </div>
        <div class="value-pill" style="--vp:#1A1F3D;--vt:#6B8AE8">
          <div class="vp-icon">↑</div>
          <div><h4>Built to Scale</h4><p>Architecture decisions for where your business will be in 3 years.</p></div>
        </div>
        <div class="value-pill" style="--vp:#2A1A3D;--vt:#B87AE8">
          <div class="vp-icon">🔒</div>
          <div><h4>Security First</h4><p>JWT auth, OWASP-aware code, and production-hardened infrastructure.</p></div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════ CONTACT ══════════════ -->
<section id="contact" class="contact-section">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-left">
        <p class="section-label">Start a Project</p>
        <h2 class="contact-h2">Let's build<br/>something that<br/><em>actually works.</em></h2>
        <p class="contact-sub">Tell us what you're building. We'll send you a proposal within 24 hours — timeline, tech stack, and investment. No calls until you've seen a plan.</p>
        <div class="contact-links">
          <a href="https://wa.me/919421462238" target="_blank" rel="noopener" class="c-link">
            <div class="c-link-icon" style="background:#1A4A47">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 2C5.6 2 2 5.6 2 10c0 1.4.4 2.8 1 4L2 18l4.2-.9c1.1.6 2.4.9 3.8.9 4.4 0 8-3.6 8-8s-3.6-8-8-8z" stroke="#5ECFB8" stroke-width="1.2"/><path d="M7.5 8.5c.5 1 1.2 2 2 2.5.8.5 1.5.7 2 .5l.5-.2c.2-.1.2-.3.1-.5l-.7-1c-.1-.2-.3-.2-.5-.1l-.4.3c-.1.1-.3.1-.4 0-.6-.4-1.2-1-1.4-1.7 0-.1 0-.3.1-.4l.3-.4c.1-.2.1-.4-.1-.5l-1-.7c-.2-.1-.4-.1-.5.1l-.2.5c-.2.5 0 1.2.2 1.6z" fill="#5ECFB8" opacity="0.9"/></svg>
            </div>
            <div><p class="c-label">WhatsApp</p><p class="c-val">+91 94214 62238</p></div>
          </a>
          <a href="mailto:contact@quantaverse.in" class="c-link">
            <div class="c-link-icon" style="background:#3D1F1A">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="2" y="4" width="16" height="12" rx="1.5" stroke="#E8865A" stroke-width="1.2"/><path d="M2 6L10 11L18 6" stroke="#E8865A" stroke-width="1.2" stroke-linecap="round"/></svg>
            </div>
            <div><p class="c-label">Email</p><p class="c-val">contact@quantaverse.in</p></div>
          </a>
        </div>
      </div>
      <div class="contact-right">
        <form id="contact-form" netlify name="contact" method="POST">
          <input type="hidden" name="form-name" value="contact" />
          <div class="cf-row">
            <input type="text"  name="name"    placeholder="Your Name"    class="cf-input" required />
            <input type="text"  name="company" placeholder="Company"      class="cf-input" />
          </div>
          <input type="email" name="email"   placeholder="Email Address" class="cf-input" required />
          <input type="tel"   name="phone"   placeholder="WhatsApp Number" class="cf-input" />
          <select name="service" class="cf-input" required>
            <option value="" disabled selected>What are you building?</option>
            <option>Mobile App (iOS / Android)</option>
            <option>Booking & Payment Platform</option>
            <option>SaaS Product</option>
            <option>AI Tools & Automation</option>
            <option>Business Website</option>
            <option>Custom Software</option>
            <option>Not sure — let's talk</option>
          </select>
          <textarea name="message" rows="4" placeholder="Tell us about your project — what it does, who it's for, and when you need it." class="cf-input" style="resize:none"></textarea>
          <button type="submit" class="cf-btn">
            Send Enquiry
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          </button>
          <p id="form-ok" class="form-ok">Thank you — we'll be in touch within 24 hours.</p>
        </form>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════ FOOTER ══════════════ -->
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div>
        <svg width="148" height="40" viewBox="0 0 160 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g transform="translate(0,2)">
