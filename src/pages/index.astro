  .mob-link:hover { color:#C9A96E; }

  /* ── HERO ── */
  /* Desktop: full viewport, content anchored to bottom */
  #hero { position:relative; height:100vh; min-height:640px; overflow:hidden; display:flex; flex-direction:column; justify-content:flex-end; }
  /* Mobile: natural height, content starts below nav */
  @media(max-width:767px) { #hero { height:auto; min-height:0; padding-top:5.5rem; padding-bottom:2rem; justify-content:flex-start; } }
  #hero-canvas { position:absolute; inset:0; width:100%; height:100%; z-index:0; pointer-events:none; }

  /* Watermark */
  .hero-watermark { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-family:'Plus Jakarta Sans',sans-serif; font-size:clamp(100px,20vw,260px); font-weight:800; letter-spacing:-0.04em; color:transparent; -webkit-text-stroke:1px rgba(201,169,110,0.07); white-space:nowrap; z-index:1; pointer-events:none; will-change:transform; user-select:none; }

  /* Badge: absolute on desktop (sits below nav), in-flow on mobile */
  .hero-badge { position:absolute; top:7rem; left:1.5rem; z-index:3; display:inline-flex; align-items:center; gap:10px; font-size:11px; letter-spacing:0.35em; text-transform:uppercase; color:rgba(245,239,228,0.55); border:1px solid rgba(245,239,228,0.12); padding:8px 18px; border-radius:100px; backdrop-filter:blur(8px); background:rgba(15,13,11,0.3); }
  @media(min-width:768px)  { .hero-badge { left:3rem; } }
  @media(min-width:1024px) { .hero-badge { left:5rem; } }
  /* On mobile badge becomes in-flow, not absolute */
  @media(max-width:767px)  { .hero-badge { position:relative; top:auto; left:auto; margin-bottom:1.5rem; } }
  .hero-badge-dot { width:6px; height:6px; border-radius:50%; background:#C9A96E; animation:pulse 2s ease-in-out infinite; }

  .hero-text { position:relative; z-index:2; padding:0 1.5rem; width:100%; max-width:1280px; margin:0 auto; }
  @media(min-width:768px)  { .hero-text { padding:0 3rem; } }
  @media(min-width:1024px) { .hero-text { padding:0 5rem; } }

  /* h1 — starts clipped, GSAP wipes it in after preloader */
  .hero-h1 {
    font-family:'Plus Jakarta Sans',sans-serif;
    font-size:clamp(36px,4.2vw,62px); font-weight:800; line-height:1.0;
