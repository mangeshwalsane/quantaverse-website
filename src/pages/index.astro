  .counter-item { background: #1C1917; padding: 2.5rem; text-align: center; }
  .counter-num {
    font-size: clamp(40px,5.5vw,72px); font-weight: 300; color: #C9A96E; line-height: 1; margin-bottom: 0.75rem;
  }
  .counter-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,239,228,0.3); }

  .charts-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 768px) { .charts-grid { grid-template-columns: repeat(3,1fr); } }
  .chart-card {
    background: #2A2320; border: 1px solid rgba(245,239,228,0.05); padding: 2rem;
  }
  .chart-eyebrow { font-size: 10px; letter-spacing: 0.4em; text-transform: uppercase; color: #C9A96E; margin-bottom: 0.5rem; }
  .chart-title { font-size: 1.2rem; font-weight: 300; color: #F5EFE4; margin-bottom: 1.5rem; }
  .chart-donut-wrap { display: flex; justify-content: center; margin-bottom: 1.5rem; }
  .chart-legend { display: flex; flex-direction: column; gap: 0.5rem; }
  .legend-row { display: flex; align-items: center; gap: 0.5rem; font-size: 11px; color: rgba(245,239,228,0.4); }
  .legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .ml-auto { margin-left: auto; }

  .cap-bars { display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 1.5rem; }
  .cap-row {}
  .cap-labels { display: flex; justify-content: space-between; font-size: 11px; color: rgba(245,239,228,0.38); margin-bottom: 0.5rem; }
  .cap-track { height: 1px; background: rgba(245,239,228,0.08); position: relative; }
  .cap-fill { position: absolute; left: 0; top: 0; height: 1px; background: #C9A96E; width: 0; transition: width 1.4s cubic-bezier(0.4,0,0.2,1); }
  .radar-wrap { display: flex; justify-content: center; }

  /* ── WORK ── */
  .work-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 1024px) { .work-grid { grid-template-columns: repeat(2,1fr); } }

  .work-card {
    border: 1px solid rgba(245,239,228,0.07); background: #2A2320;
    transition: border-color 0.3s, transform 0.3s;
  }
  .work-card:hover { border-color: rgba(201,169,110,0.3); transform: translateY(-5px); }
  .work-card-featured { grid-column: 1 / -1; }
  .work-card-featured > div { display: grid; grid-template-columns: 1fr; min-height: 400px; }
  @media (min-width: 1024px) { .work-card-featured > div { grid-template-columns: 1fr 1fr; } }

  .work-card-info { padding: 3rem; display: flex; flex-direction: column; justify-content: space-between; }
  .work-card-visual {
    background: #1C1917; min-height: 280px;
    display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative;
  }
  .work-card-visual-inner { position: relative; z-index: 1; text-align: center; padding: 2rem; }
  .fitnity-bg-glow {
    position: absolute; inset: 0;
    background: radial-gradient(circle at 60% 40%, rgba(18,112,95,0.15), transparent 60%),
                radial-gradient(circle at 20% 80%, rgba(201,169,110,0.08), transparent 50%);
  }
  .fitnity-wordmark {
    font-size: 80px; font-weight: 300; color: rgba(245,239,228,0.04);
    margin-bottom: 1.5rem; user-select: none;
  }
  .fitnity-modules { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; max-width: 280px; }
  .fmod {
    font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
    color: #12705F; border: 1px solid rgba(18,112,95,0.3); padding: 6px 14px;
  }
  .fitnity-sub { font-size: 11px; color: rgba(245,239,228,0.2); margin-top: 1.5rem; letter-spacing: 0.1em; text-transform: uppercase; }

  .work-card-sm { padding: 2.5rem; }
  .work-title  { font-size: clamp(28px,3vw,40px); font-weight: 300; color: #F5EFE4; margin-bottom: 1rem; }
  .work-title-sm { font-size: 1.75rem; font-weight: 300; color: #F5EFE4; margin-bottom: 0.75rem; }
  .work-desc { font-size: 13px; color: rgba(245,239,228,0.38); line-height: 1.75; }
  .work-btn { margin-top: 2.5rem; font-size: 11px; padding: 12px 24px; }
  .work-badges { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; }
  .mb-5 { margin-bottom: 1.25rem; }
  .mt-6 { margin-top: 1.5rem; }
  .badge-gold { font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: #C9A96E; border: 1px solid rgba(201,169,110,0.3); padding: 4px 12px; }
  .badge-muted { font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(245,239,228,0.3); border: 1px solid rgba(245,239,228,0.08); padding: 4px 12px; }
  .badge-pulse { display: inline-flex; align-items: center; gap: 6px; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,239,228,0.3); border: 1px solid rgba(245,239,228,0.08); padding: 4px 12px; }
  .badge-green { color: #4A9A6A; border-color: rgba(74,154,106,0.25); }
  .pulse-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

  /* ── ABOUT ── */
  .about-grid { display: grid; grid-template-columns: 1fr; gap: 5rem; }
  @media (min-width: 1024px) { .about-grid { grid-template-columns: 1fr 1fr; align-items: start; } }
  .about-body { display: flex; flex-direction: column; gap: 1.25rem; }
  .about-body p { font-size: 13px; color: rgba(245,239,228,0.45); line-height: 1.8; }
  .values-grid { display: grid; grid-template-columns: 1fr; gap: 1px; background: rgba(245,239,228,0.06); }
  @media (min-width: 640px) { .values-grid { grid-template-columns: repeat(2,1fr); } }
  .value-card { background: #1C1917; padding: 2rem; }
  .value-icon { width: 2rem; height: 2rem; border: 1px solid rgba(201,169,110,0.18); display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; }
  .value-title { font-size: 1.2rem; font-weight: 300; color: #F5EFE4; margin-bottom: 0.75rem; }
  .value-desc { font-size: 12px; color: rgba(245,239,228,0.32); line-height: 1.7; }

  /* ── CONTACT ── */
  .contact-grid { display: grid; grid-template-columns: 1fr; gap: 5rem; }
  @media (min-width: 1024px) { .contact-grid { grid-template-columns: 1fr 1fr; } }
  .contact-links { display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-link { display: flex; align-items: center; gap: 1.25rem; text-decoration: none; }
  .contact-link-icon {
    width: 3rem; height: 3rem; flex-shrink: 0;
    border: 1px solid rgba(201,169,110,0.2);
    display: flex; align-items: center; justify-content: center;
    transition: border-color 0.3s;
  }
  .contact-link:hover .contact-link-icon { border-color: rgba(201,169,110,0.5); }
  .contact-link-label { font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(245,239,228,0.28); margin-bottom: 0.25rem; }
  .contact-link-value { font-size: 14px; color: #F5EFE4; transition: color 0.3s; }
  .contact-link:hover .contact-link-value { color: #C9A96E; }

  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-field {
    width: 100%; background: rgba(245,239,228,0.04); border: 1px solid rgba(245,239,228,0.1);
    color: #F5EFE4; font-family: 'DM Sans', sans-serif; font-size: 14px;
    padding: 16px 20px; outline: none; transition: border-color 0.3s;
  }
  .form-field::placeholder { color: rgba(245,239,228,0.28); }
  .form-field:focus { border-color: rgba(201,169,110,0.4); }
  .form-field option { background: #2A2320; }
  .form-success { font-size: 13px; color: #4A9A6A; text-align: center; display: none; }

  /* ── FOOTER ── */
  .footer { border-top: 1px solid rgba(245,239,228,0.05); padding: 4rem 1.5rem; }
  @media (min-width: 768px)  { .footer { padding-left: 3rem; padding-right: 3rem; } }
  @media (min-width: 1024px) { .footer { padding-left: 5rem; padding-right: 5rem; } }
  .footer-top { display: flex; flex-direction: column; gap: 3rem; margin-bottom: 3rem; }
  @media (min-width: 1024px) { .footer-top { flex-direction: row; align-items: center; justify-content: space-between; } }
  .footer-logo { display: block; margin-bottom: 1rem; }
  .footer-tagline { font-size: 12px; color: rgba(245,239,228,0.28); max-width: 240px; line-height: 1.6; }
  .footer-nav { display: flex; flex-wrap: wrap; gap: 2rem 2.5rem; }
  .footer-link { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,239,228,0.28); text-decoration: none; transition: color 0.3s; }
  .footer-link:hover { color: #C9A96E; }
  .footer-bottom { display: flex; flex-direction: column; gap: 0.5rem; }
  @media (min-width: 640px) { .footer-bottom { flex-direction: row; align-items: center; justify-content: space-between; } }
  .footer-bottom p { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,239,228,0.18); }
  .footer-closing { color: rgba(201,169,110,0.45) !important; }
</style>


<!-- ══════════════ SCRIPTS ══════════════ -->
<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
import * as THREE from 'three';
import Chart from 'chart.js/auto';

gsap.registerPlugin(ScrollTrigger);

// ── NAV ──────────────────────────────────────
const nav = document.getElementById('nav')!;
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 40);
}, { passive: true });

// ── MOBILE MENU ──────────────────────────────
const mobileBtn   = document.getElementById('mobile-menu-btn')!;
const mobileMenu  = document.getElementById('mobile-menu')!;
const mobileClose = document.getElementById('mobile-close')!;
const mobileLinks = document.querySelectorAll('.mobile-nav-link');

mobileBtn.addEventListener('click',  () => mobileMenu.classList.add('open'));
mobileClose.addEventListener('click', () => mobileMenu.classList.remove('open'));
mobileLinks.forEach(l => l.addEventListener('click', () => mobileMenu.classList.remove('open')));

// ── THREE.JS HERO — enhanced ─────────────────
const canvas   = document.getElementById('hero-canvas') as HTMLCanvasElement;
const scene    = new THREE.Scene();
const camera   = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 1000);
const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
camera.position.z = 5;

// ── Particle network — varied sizes, depth, opacity
const COUNT = 800;
const pos   = new Float32Array(COUNT * 3);
const sizes = new Float32Array(COUNT);

for (let i = 0; i < COUNT; i++) {
  const depth = Math.random();
  pos[i*3]   = (Math.random() - 0.5) * 18;
  pos[i*3+1] = (Math.random() - 0.5) * 10;
  pos[i*3+2] = -depth * 8;
  // Closer particles are bigger
  sizes[i] = 0.5 + (1 - depth) * 2.5;
}
const geo = new THREE.BufferGeometry();
geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
geo.setAttribute('size',     new THREE.BufferAttribute(sizes, 1));

// Custom shader material for circular, glowing particles
const shaderMat = new THREE.ShaderMaterial({
  uniforms: { uColor: { value: new THREE.Color(0xC9A96E) }, uOpacity: { value: 0.6 } },
  vertexShader: `
    attribute float size;
    void main() {
      vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
      gl_PointSize = size * (280.0 / -mvPosition.z);
      gl_Position = projectionMatrix * mvPosition;
    }
  `,
  fragmentShader: `
    uniform vec3 uColor;
    uniform float uOpacity;
    void main() {
      float d = length(gl_PointCoord - vec2(0.5));
      if (d > 0.5) discard;
      float alpha = (1.0 - d * 2.0) * uOpacity;
      gl_FragColor = vec4(uColor, alpha);
    }
  `,
  transparent: true,
  depthWrite: false,
});
scene.add(new THREE.Points(geo, shaderMat));

// ── Subtle gold grid — very faint depth plane
const gridMat = new THREE.LineBasicMaterial({ color: 0xC9A96E, transparent: true, opacity: 0.03 });
for (let i = -6; i <= 6; i++) {
  const gv = new THREE.BufferGeometry().setFromPoints([
    new THREE.Vector3(i * 1.8, -6, -4), new THREE.Vector3(i * 1.8, 6, -4)
  ]);
  const gh = new THREE.BufferGeometry().setFromPoints([
    new THREE.Vector3(-11, i * 1.1, -4), new THREE.Vector3(11, i * 1.1, -4)
  ]);
  scene.add(new THREE.Line(gv, gridMat));
  scene.add(new THREE.Line(gh, gridMat));
}

// ── Floating rings — elegant, slowly rotating
const makeRing = (r1: number, r2: number, color: number, opacity: number, x: number, y: number, z: number) => {
  const m = new THREE.Mesh(
    new THREE.RingGeometry(r1, r2, 80),
    new THREE.MeshBasicMaterial({ color, transparent: true, opacity, side: THREE.DoubleSide })
  );
  m.position.set(x, y, z);
  scene.add(m);
  return m;
};
const ring1 = makeRing(1.4, 1.46, 0xC9A96E, 0.12, 3.5,  1.2, -1.5);
const ring2 = makeRing(0.7, 0.74, 0xC4714A, 0.10, -4.5, -1.8, -2.0);
const ring3 = makeRing(0.4, 0.43, 0xC9A96E, 0.08, 1.5, -2.5, -0.5);

// ── Subtle nebula glow blob (additive sphere)
const glowGeo = new THREE.SphereGeometry(2.5, 32, 32);
const glowMat = new THREE.MeshBasicMaterial({ color: 0xC9A96E, transparent: true, opacity: 0.018, side: THREE.BackSide });
const glow1 = new THREE.Mesh(glowGeo, glowMat);
glow1.position.set(3, 0, -3);
scene.add(glow1);

let mouseX = 0, mouseY = 0;
window.addEventListener('mousemove', (e) => {
  mouseX = (e.clientX / window.innerWidth  - 0.5) * 2;
  mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
}, { passive: true });

let raf: number;
let heroActive = true;

function animateHero() {
  if (!heroActive) return;
  raf = requestAnimationFrame(animateHero);
  const t = Date.now() * 0.00025;

  camera.position.x += (mouseX * 0.35 - camera.position.x) * 0.035;
  camera.position.y += (-mouseY * 0.18 - camera.position.y) * 0.035;
  camera.lookAt(scene.position);

  ring1.rotation.z = t * 0.25;
  ring1.rotation.x = t * 0.08;
  ring2.rotation.z = -t * 0.4;
  ring2.rotation.y = t * 0.12;
  ring3.rotation.z = t * 0.6;

  // Slowly drift particles
  const positions = (geo.attributes.position as THREE.BufferAttribute).array as Float32Array;
  for (let i = 0; i < COUNT; i++) {
    positions[i*3+1] += 0.0003;
    if (positions[i*3+1] > 5) positions[i*3+1] = -5;
  }
  geo.attributes.position.needsUpdate = true;

  renderer.render(scene, camera);
}
animateHero();

ScrollTrigger.create({
  trigger: '#hero', start: 'top top', end: 'bottom top',
  onLeave:      () => { heroActive = false; cancelAnimationFrame(raf); },
  onEnterBack:  () => { heroActive = true; animateHero(); },
});

window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
}, { passive: true });

// ── GSAP REVEALS — use data-delay attribute ───
gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
  const delay = parseFloat(el.dataset.delay || '0');
  gsap.fromTo(el,
    { opacity: 0, y: 30 },
    { opacity: 1, y: 0, duration: 0.85, ease: 'power3.out', delay,
      scrollTrigger: { trigger: el, start: 'top 90%', once: true }
    }
  );
});

// ── COUNTERS ────────────────────────────────
document.querySelectorAll<HTMLElement>('[data-counter]').forEach((el) => {
  const target = parseInt(el.dataset.counter!, 10);
  const suffix = el.dataset.suffix || '';
  ScrollTrigger.create({
    trigger: el, start: 'top 85%', once: true,
    onEnter: () => {
      const obj = { val: 0 };
      gsap.to(obj, { val: target, duration: 2, ease: 'power2.out',
        onUpdate() { el.textContent = Math.round(obj.val) + suffix; }
      });
    }
  });
});

// ── CHARTS ─────────────────────────────────
ScrollTrigger.create({
  trigger: '#stats', start: 'top 70%', once: true,
  onEnter() {
    // Donut
    const ctxD = (document.getElementById('chart-tech') as HTMLCanvasElement).getContext('2d')!;
    new Chart(ctxD, {
      type: 'doughnut',
      data: {
        labels: ['Mobile Apps','Backend APIs','Web Platforms','AI & Automation'],
        datasets: [{
          data: [30,25,25,20],
          backgroundColor: ['#C9A96E','#C4714A','#8C7B6B','#4A6741'],
          borderColor: '#2A2320', borderWidth: 3, hoverOffset: 8,
        }]
      },
      options: {
        cutout: '72%',
        plugins: {
          legend: { display: false },
          tooltip: { backgroundColor: '#2A2320', titleColor: '#F5EFE4', bodyColor: '#8C7B6B', borderColor: 'rgba(201,169,110,0.2)', borderWidth: 1 }
        },
        animation: { animateRotate: true, duration: 1400, easing: 'easeInOutQuart' }
      }
    });

    // Bar
    const ctxB = (document.getElementById('chart-speed') as HTMLCanvasElement).getContext('2d')!;
    new Chart(ctxB, {
      type: 'bar',
      data: {
        labels: ['Static Site','Booking','Mobile App','SaaS'],
        datasets: [
          { label: 'Quantaverse', data: [12,15,20,25], backgroundColor: 'rgba(201,169,110,0.75)', borderColor: '#C9A96E', borderWidth: 1, borderRadius: 2 },
          { label: 'Industry Avg', data: [30,60,90,120], backgroundColor: 'rgba(140,123,107,0.18)', borderColor: 'rgba(140,123,107,0.35)', borderWidth: 1, borderRadius: 2 }
        ]
      },
      options: {
        plugins: {
          legend: { labels: { color: 'rgba(245,239,228,0.38)', font: { family: 'DM Sans', size: 11 }, boxWidth: 12 } },
          tooltip: { backgroundColor: '#2A2320', titleColor: '#F5EFE4', bodyColor: '#8C7B6B', borderColor: 'rgba(201,169,110,0.2)', borderWidth: 1,
            callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y} days` } }
        },
        scales: {
          x: { ticks: { color: 'rgba(245,239,228,0.3)', font: { family: 'DM Sans', size: 10 } }, grid: { color: 'rgba(245,239,228,0.04)' } },
          y: { ticks: { color: 'rgba(245,239,228,0.3)', font: { family: 'DM Sans', size: 10 }, callback: v => v + 'd' }, grid: { color: 'rgba(245,239,228,0.04)' } }
        },
        animation: { duration: 1400, easing: 'easeInOutQuart' }
      }
    });

    // Capability bars
    document.querySelectorAll<HTMLElement>('.cap-fill').forEach((bar, i) => {
      const w = bar.dataset.w!;
      setTimeout(() => { bar.style.width = w + '%'; }, i * 100);
    });

    // Radar
    const poly = document.getElementById('radar-polygon')!;
    poly.style.transition = 'opacity 1s ease 0.4s';
    poly.style.opacity = '1';
    document.querySelectorAll<SVGCircleElement>('.radar-dot').forEach((d, i) => {
      d.style.transition = `opacity 0.4s ease ${0.6 + i * 0.1}s`;
      d.style.opacity = '1';
    });
  }
});

// ── CONTACT FORM ────────────────────────────
const form = document.getElementById('contact-form') as HTMLFormElement;
form.addEventListener('submit', async (e) => {
  e.preventDefault();
  try {
    await fetch('/', { method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(new FormData(form) as any).toString()
    });
    form.reset();
    const s = document.getElementById('form-success')!;
    s.style.display = 'block';
  } catch { /* silent */ }
});
</script>

</body>
