<!-- ══════════════ SCRIPTS ══════════════ -->
<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
import Chart from 'chart.js/auto';
import Lenis from '@studio-freight/lenis';

gsap.registerPlugin(ScrollTrigger);

// ══════════════════════════════════════════
// 0. LENIS SMOOTH SCROLL
// ══════════════════════════════════════════
const lenis = new Lenis({
  duration: 1.2,
  easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
  smoothWheel: true,
  wheelMultiplier: 0.9,
  touchMultiplier: 1.6,
});

// Sync GSAP ScrollTrigger with Lenis
lenis.on('scroll', ScrollTrigger.update);
gsap.ticker.add((time: number) => lenis.raf(time * 1000));
gsap.ticker.lagSmoothing(0);

// ══════════════════════════════════════════
// 1. PRELOADER — Quantum Superposition Engine
// ══════════════════════════════════════════
(function() {
  const container = document.getElementById('quantum-superposition-loader') as HTMLElement;
  const canvas    = document.getElementById('quantum-loader-canvas') as HTMLCanvasElement;
  const statusEl  = document.getElementById('loader-status') as HTMLElement;
  if (!canvas || !container) return;

  const ctx = canvas.getContext('2d')!;

  // DPR-aware resolution — sharp on Retina
  const DPR = Math.min(window.devicePixelRatio || 1, 2);
  const SIZE = 400;
  canvas.width  = SIZE * DPR;
  canvas.height = SIZE * DPR;
  ctx.scale(DPR, DPR);

  const CX = SIZE / 2, CY = SIZE / 2;
  const GOLD = 'rgba(201,169,110,';

  let angle           = 0;
  let isLoaded        = false;
  let collapseT       = 0;   // 0→1 collapse progress
  let rafId           = 0;

  // Status text cycling during load
  const STATUS_MSGS = [
    'CALIBRATING SYSTEMS...',
    'ALIGNING QUANTUM STATE...',
    'LOADING INFRASTRUCTURE...',
    'INITIALISING...',
  ];
  let statusIdx = 0;
  const statusTimer = setInterval(() => {
    statusIdx = (statusIdx + 1) % (STATUS_MSGS.length - 1); // cycle first 3 only
    statusEl.textContent = STATUS_MSGS[statusIdx];
  }, 900);

  // Hook: if page already loaded (fast CDN), fire immediately
  if (document.readyState === 'complete') {
    isLoaded = true;
  } else {
    window.addEventListener('load', () => { isLoaded = true; }, { once: true });
  }

  function drawWaveforms() {
    const waveCount = 4;
    for (let i = 0; i < waveCount; i++) {
      const phase        = angle + (i * Math.PI / 2);
      const radiusOffset = Math.sin(phase) * 35;
      const radius       = 60 + radiusOffset;
      const alpha        = 0.12 + i * 0.055;

      // Ring
      ctx.beginPath();
      ctx.arc(CX, CY, radius, 0, Math.PI * 2);
      ctx.strokeStyle = GOLD + alpha + ')';
      ctx.lineWidth   = 0.8 + i * 0.45;
      ctx.stroke();

      // Orbital particle — each wave has a slightly different angular speed
      const orbitSpeed = angle * (1 - i * 0.08);
      const ox = CX + Math.cos(orbitSpeed) * radius;
      const oy = CY + Math.sin(orbitSpeed) * radius;

      ctx.beginPath();
      ctx.arc(ox, oy, 1.8, 0, Math.PI * 2);
      ctx.fillStyle = GOLD + Math.min(alpha + 0.35, 0.9) + ')';
      ctx.fill();

      // Secondary counter-rotating particle on outer two waves
      if (i >= 2) {
        const ox2 = CX + Math.cos(-orbitSpeed * 0.7 + Math.PI) * radius;
        const oy2 = CY + Math.sin(-orbitSpeed * 0.7 + Math.PI) * radius;
        ctx.beginPath();
        ctx.arc(ox2, oy2, 1.2, 0, Math.PI * 2);
        ctx.fillStyle = GOLD + (alpha + 0.2) + ')';
        ctx.fill();
      }
    }

    // Faint centre dot — anchor point
    ctx.beginPath();
    ctx.arc(CX, CY, 2, 0, Math.PI * 2);
    ctx.fillStyle = GOLD + '0.3)';
    ctx.fill();
  }

  function drawCollapse() {
    // Acceleration curve: ease-in so it snaps fast at the end
    const eased  = collapseT * collapseT * (3 - 2 * collapseT); // smoothstep
    const radius = Math.max(0, 62 * (1 - eased));
    const alpha  = 1 - eased;

    // Shrinking ring
    if (radius > 0.5) {
      ctx.beginPath();
      ctx.arc(CX, CY, radius, 0, Math.PI * 2);
      ctx.strokeStyle = GOLD + (alpha * 0.6) + ')';
      ctx.lineWidth   = 1.5;
      ctx.stroke();
    }

    // Imploding fill dot
    ctx.beginPath();
    ctx.arc(CX, CY, Math.max(0, radius * 0.18 + 2), 0, Math.PI * 2);
    ctx.fillStyle = GOLD + alpha + ')';
    ctx.fill();

    // Brief radial flash at moment of full collapse (collapseT > 0.85)
    if (collapseT > 0.85) {
      const flashR = (collapseT - 0.85) / 0.15 * 28;
      const flashA = (1 - (collapseT - 0.85) / 0.15) * 0.18;
      ctx.beginPath();
      ctx.arc(CX, CY, flashR, 0, Math.PI * 2);
      ctx.strokeStyle = GOLD + flashA + ')';
      ctx.lineWidth = 1;
      ctx.stroke();
    }
  }

  function tick() {
    ctx.clearRect(0, 0, SIZE, SIZE);
    angle += 0.038;

    if (!isLoaded) {
      drawWaveforms();
      rafId = requestAnimationFrame(tick);
      return;
    }

    // Transition status text once on first loaded frame
    if (collapseT === 0) {
      clearInterval(statusTimer);
      statusEl.textContent = STATUS_MSGS[3]; // "INITIALISING..."
    }

    // Collapse: accelerate faster in later frames
    collapseT = Math.min(collapseT + 0.028 + collapseT * 0.04, 1);
    drawCollapse();

    if (collapseT >= 1) {
      cancelAnimationFrame(rafId);
      // Lens-shutter clip-path wipe
      container.classList.add('collapse-sequence');
      // Fire site launch after wipe transition completes (1.4s)
      setTimeout(() => {
        container.style.display = 'none';
        clipPathHeroReveal();
        initParticles();
      }, 1450);
      return;
    }

    rafId = requestAnimationFrame(tick);
  }

  rafId = requestAnimationFrame(tick);
})();

// ══════════════════════════════════════════
// 2. HERO REVEAL — clip-path text-mask wipe
// ══════════════════════════════════════════
function clipPathHeroReveal() {
  const h1 = document.getElementById('hero-h1')!;
  const badge = document.querySelector<HTMLElement>('.hero-badge');
  const iconCard = document.querySelector<HTMLElement>('.hero-icon-card');
  const heroBottom = document.querySelector<HTMLElement>('.hero-bottom');

  // Wrap each line's text in a clip container for wipe effect
  const lines = h1.querySelectorAll<HTMLElement>('br');
  // Instead of wrapping lines (complex with inline HTML), we animate h1 as a whole
  // with clip-path sliding up — premium wipe reveal
  h1.style.clipPath = 'inset(100% 0% 0% 0%)';
  h1.style.opacity = '1';

  const tl = gsap.timeline({ delay: 0.1 });

  tl.to(h1, {
    clipPath: 'inset(0% 0% 0% 0%)',
    duration: 1.0,
    ease: 'power4.out',
  });

  if (badge) {
    tl.fromTo(badge,
      { opacity: 0, y: 12, filter: 'blur(6px)' },
      { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.6, ease: 'power3.out' },
      '-=0.5'
    );
  }
  if (iconCard) {
    tl.fromTo(iconCard,
      { opacity: 0, y: 20, filter: 'blur(6px)' },
      { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.7, ease: 'power3.out' },
      '-=0.4'
    );
  }
  if (heroBottom) {
    tl.fromTo(heroBottom,
      { opacity: 0, y: 24 },
      { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' },
      '-=0.35'
    );
  }
}

// ══════════════════════════════════════════
// 3. SCROLL PROGRESS BAR
// ══════════════════════════════════════════
const scrollBar = document.getElementById('scroll-bar')!;
window.addEventListener('scroll', () => {
  const pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight) * 100;
  scrollBar.style.width = Math.min(pct, 100) + '%';
}, { passive: true });

// ══════════════════════════════════════════
// 4. CUSTOM CURSOR — morphing ring
// ══════════════════════════════════════════
const dot  = document.getElementById('cursor-dot')!;
const ring = document.getElementById('cursor-ring')!;
let cx = 0, cy = 0, rx = 0, ry = 0;

const isTouch = window.matchMedia('(hover:none)').matches;
if (!isTouch) {
  window.addEventListener('mousemove', e => { cx = e.clientX; cy = e.clientY; }, { passive: true });

  function trackCursor() {
    dot.style.left  = cx + 'px';
    dot.style.top   = cy + 'px';
    rx += (cx - rx) * 0.12;
    ry += (cy - ry) * 0.12;
    ring.style.left = rx + 'px';
    ring.style.top  = ry + 'px';
    requestAnimationFrame(trackCursor);
  }
  trackCursor();

  // Ring morphs: expand on cards/links, hollow glow ring on CTA buttons
  const CTA_SELECTORS = '.magnetic-btn,.hero-cta,.cf-btn,.nav-cta,.about-cta';
  const HOVER_SELECTORS = 'a,button,.svc-card,.work-card,.value-pill';

  document.querySelectorAll<HTMLElement>(HOVER_SELECTORS).forEach(el => {
    const isCta = el.matches(CTA_SELECTORS);
    el.addEventListener('mouseenter', () => {
      if (isCta) {
        ring.classList.remove('expand');
        ring.classList.add('cta-hover');
        dot.style.opacity = '0';
        dot.style.transform = 'translate(-50%,-50%) scale(0)';
      } else {
        ring.classList.add('expand');
      }
    });
    el.addEventListener('mouseleave', () => {
      ring.classList.remove('expand','cta-hover');
      dot.style.opacity = '';
      dot.style.transform = '';
    });
  });
}

