  .hero-icon-caption { font-size:11px; font-weight:300; color:rgba(245,239,228,0.35); letter-spacing:0.02em; }

  /* ── MINI STATS STRIP ── */
  .hero-mini-stats { display:flex; align-items:center; gap:1rem; margin-top:1rem; flex-wrap:wrap; }
