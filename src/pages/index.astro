---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Quantaverse Labs Pvt Ltd builds mobile apps, SaaS platforms, booking systems, AI tools, and custom digital infrastructure for businesses. Build once. Automate forever." />
  <meta property="og:title" content="Quantaverse Labs — We design, build, and automate digital businesses." />
  <meta property="og:description" content="Custom mobile apps, SaaS, booking systems, AI tools. Build once. Automate forever." />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#030712" />
  <title>Quantaverse Labs — We design, build, and automate digital businesses.</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ══════════════ SCROLL PROGRESS BAR ══════════════ -->
<div id="scroll-bar"></div>

<!-- ══════════════ CUSTOM CURSOR ══════════════ -->
<canvas id="cursor-canvas"></canvas>
<div id="cursor-dot"></div>
<div id="cursor-ring"></div>

<!-- ══════════════ PRELOADER ══════════════ -->
<div id="quantum-superposition-loader">
  <canvas id="quantum-loader-canvas"></canvas>
  <div class="loader-status-text" id="loader-status">CALIBRATING SYSTEMS...</div>
</div>

<div class="grain" aria-hidden="true"></div>

<!-- ══════════════ NAV ══════════════ -->
<nav id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <svg width="160" height="44" viewBox="0 0 160 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(0,2)">
          <rect x="2" y="9" width="18" height="18" rx="1.2" stroke="#C9A96E" stroke-width="1.1" transform="rotate(45 11 18)" fill="none"/>
          <rect x="5.5" y="12.5" width="11" height="11" rx="0.8" stroke="#C9A96E" stroke-width="0.7" opacity="0.4" transform="rotate(45 11 18)" fill="none"/>
          <rect x="8" y="15" width="6" height="6" rx="0.4" fill="#C9A96E" opacity="0.85" transform="rotate(45 11 18)"/>
        </g>
        <text x="35" y="19" font-family="'DM Sans',sans-serif" font-size="11" font-weight="600" letter-spacing="2.5" fill="#F5EFE4">QUANTAVERSE</text>
        <text x="35" y="34" font-family="'DM Sans',sans-serif" font-size="8.5" font-weight="300" letter-spacing="4.5" fill="#C9A96E">LABS  PVT  LTD</text>
      </svg>
    </a>
    <a href="#contact" class="nav-cta magnetic-btn">Start a Project</a>
    <button id="mob-btn" class="mob-btn" aria-label="Menu">
      <span></span><span></span>
    </button>
  </div>
</nav>

<div id="mob-overlay" class="mob-overlay">
  <button id="mob-close" aria-label="Close">✕</button>
  <a href="#services" class="mob-link">Services</a>
  <a href="#work"     class="mob-link">Work</a>
  <a href="#about"    class="mob-link">About</a>
  <a href="#contact"  class="mob-link">Contact</a>
</div>


<!-- ══════════════ HERO ══════════════ -->
<section id="hero">
  <canvas id="hero-canvas"></canvas>

  <!-- Giant watermark word -->
  <div class="hero-watermark" id="hero-watermark">BUILD</div>

  <div class="hero-badge">
    <span class="hero-badge-dot"></span>
    Digital Infrastructure Studio
  </div>

  <div class="hero-text">
    <h1 class="hero-h1" id="hero-h1">
      We design,<br/>
      build, and<br/>
      <em>automate</em><br/>
      digital<br/>
      businesses.
    </h1>

    <!-- ── VISUAL ICON CARD ── -->
    <div class="hero-icon-card">
      <div class="hero-icon-row">
        <div class="hero-icon-box hib-dark">📱</div>
        <span class="hero-icon-plus">+</span>
        <div class="hero-icon-box hib-terra">🌐</div>
        <span class="hero-icon-plus">+</span>
        <div class="hero-icon-box hib-gold">⚡</div>
      </div>
      <div class="hero-icon-text">
        <p class="hero-icon-title">Apps. Platforms. Automation.</p>
        <p class="hero-icon-caption">One studio. Full stack. Production-ready.</p>
      </div>
    </div>

    <div class="hero-bottom">
      <div class="hero-bottom-left">
        <p class="hero-sub">From fitness marketplaces to booking engines, SaaS platforms, and AI workflows — software that removes manual operations.</p>
        <!-- ── MINI STATS STRIP ── -->
        <div class="hero-mini-stats">
          <div class="hero-mini-stat">
            <span class="hms-num">15<span class="hms-unit">d</span></span>
            <span class="hms-label">Avg. delivery</span>
          </div>
          <div class="hms-divider"></div>
          <div class="hero-mini-stat">
            <span class="hms-num">0<span class="hms-unit">%</span></span>
            <span class="hms-label">Lock-in</span>
          </div>
          <div class="hms-divider"></div>
          <div class="hero-mini-stat">
            <span class="hms-num">100<span class="hms-unit">%</span></span>
            <span class="hms-label">Code ownership</span>
          </div>
        </div>
      </div>
      <a href="#contact" class="hero-cta magnetic-btn">
        Start a Project
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9H14M14 9L10 5M14 9L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </a>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="hero-scroll-line"></div>
    <span>scroll</span>
  </div>
</section>


<!-- ══════════════ MARQUEE ══════════════ -->
<div class="marquee-wrap">
  <div class="marquee-track">
    <span>Mobile Apps</span><span class="marquee-dot">◆</span>
    <span class="marquee-outline">SaaS Platforms</span><span class="marquee-dot">◆</span>
    <span>Booking Systems</span><span class="marquee-dot">◆</span>
    <span class="marquee-outline">AI Automation</span><span class="marquee-dot">◆</span>
    <span>Business Websites</span><span class="marquee-dot">◆</span>
    <span class="marquee-outline">Custom Software</span><span class="marquee-dot">◆</span>
    <span>Mobile Apps</span><span class="marquee-dot">◆</span>
    <span class="marquee-outline">SaaS Platforms</span><span class="marquee-dot">◆</span>
    <span>Booking Systems</span><span class="marquee-dot">◆</span>
    <span class="marquee-outline">AI Automation</span><span class="marquee-dot">◆</span>
    <span>Business Websites</span><span class="marquee-dot">◆</span>
    <span class="marquee-outline">Custom Software</span><span class="marquee-dot">◆</span>
  </div>
</div>


<!-- ══════════════ SERVICES ══════════════ -->
<section id="services" class="services-section">
  <div class="container">
    <div class="svc-header reveal-up">
      <p class="section-label">What We Do</p>
      <h2 class="svc-h2">Six ways we build your<br/><em>digital infrastructure</em></h2>
    </div>

    <div class="svc-grid">
      <div class="svc-card svc-tall tilt-card" style="--bg:#0D3B35;--accent:#3ECFB2;--num-c:rgba(62,207,178,0.08)">
        <div class="tilt-glow"></div>
        <div class="svc-inner">
          <div class="svc-num">01</div>
          <div class="svc-body">
            <h3>Mobile Apps</h3>
            <p>iOS and Android apps built with Flutter — one codebase, two stores. We ship production-grade apps with real backend integrations.</p>
            <!-- Mobile app phone mockup micro-demo -->
            <div class="mobile-demo" id="svc-mobile-demo">
              <div class="md-phone">
                <div class="md-notch"></div>
                <div class="md-screen">
                  <div class="md-statusbar"><span class="md-time">9:41</span><span class="md-signal">●●●</span></div>
                  <div class="md-app">
                    <div class="md-appbar"><span class="md-appname">fitnity</span><span class="md-notif-dot">2</span></div>
                    <div class="md-tabs">
                      <span class="md-tab md-tab-active">Gym</span>
                      <span class="md-tab">Yoga</span>
                      <span class="md-tab">Sports</span>
                    </div>
                    <div class="md-card-preview">
                      <div class="md-card-img"></div>
                      <div class="md-card-info">
                        <div class="md-card-title"></div>
                        <div class="md-card-sub"></div>
                        <div class="md-card-rating"><span class="md-star">★</span><span class="md-rating-val">4.8</span></div>
                      </div>
                    </div>
                    <div class="md-rows">
                      <div class="md-row r1"></div>
                      <div class="md-row r2"></div>
                    </div>
                    <div class="md-btn">Book Now</div>
                  </div>
                  <div class="md-homebar"></div>
                </div>
              </div>
              <div class="md-side">
                <div class="md-stat-row">
                  <div class="md-stat">
                    <span class="md-stat-val">10K+</span>
                    <span class="md-stat-lbl">Downloads</span>
                  </div>
                  <div class="md-stat">
                    <span class="md-stat-val">4.8★</span>
                    <span class="md-stat-lbl">Rating</span>
                  </div>
                </div>
                <div class="md-feature-list">
                  <div class="md-feat"><span class="md-feat-dot"></span>Real-time booking</div>
                  <div class="md-feat"><span class="md-feat-dot"></span>Razorpay payments</div>
                  <div class="md-feat"><span class="md-feat-dot"></span>Push notifications</div>
                  <div class="md-feat"><span class="md-feat-dot"></span>Live class tracking</div>
                </div>
                <div class="md-store-row">
                  <span class="md-badge">App Store</span>
                  <span class="md-badge">Play Store</span>
                </div>
              </div>
            </div>
            <div class="svc-tags"><span>Flutter</span><span>iOS</span><span>Android</span><span>Firebase</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-circle" style="background:rgba(62,207,178,0.1)"></div>
      </div>

      <div class="svc-card svc-wide tilt-card" style="--bg:#3D1A12;--accent:#F07A4A;--num-c:rgba(240,122,74,0.08)">
        <div class="tilt-glow"></div>
        <div class="svc-inner">
          <div class="svc-num">02</div>
          <div class="svc-body">
            <h3>Booking & Payments</h3>
            <p>End-to-end booking systems with Razorpay, real-time availability, automated confirmations, and calendar sync. Zero manual work.</p>
            <!-- Payment processing micro-demo -->
            <div id="svc-payment-demo" class="pay-demo">
              <div class="pay-step"><span class="pay-icon">💳</span><span>Card verified</span></div>
              <div class="pay-step"><span class="pay-icon">🔐</span><span>3D Secure passed</span></div>
              <div class="pay-step"><span class="pay-icon">✓</span><span>Payment captured</span></div>
              <div class="pay-step"><span class="pay-icon">📧</span><span>Confirmation sent</span></div>
            </div>
            <div class="svc-tags"><span>Razorpay</span><span>Calendar</span><span>Webhooks</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-ring" style="border-color:rgba(240,122,74,0.15)"></div>
      </div>

      <div class="svc-card tilt-card" style="--bg:#111836;--accent:#7B9EF0;--num-c:rgba(123,158,240,0.08)">
        <div class="tilt-glow"></div>
        <div class="svc-inner">
          <div class="svc-num">03</div>
          <div class="svc-body">
            <h3>SaaS Platforms</h3>
            <p>Multi-tenant SaaS with subscription billing, role-based access, and analytics. Scales from 10 to 10,000 users.</p>
            <div class="svc-tags"><span>Spring Boot</span><span>PostgreSQL</span><span>AWS</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-pill" style="background:rgba(123,158,240,0.08)"></div>
      </div>

      <div class="svc-card tilt-card" style="--bg:#1E1130;--accent:#C47AE8;--num-c:rgba(196,122,232,0.08)">
        <div class="tilt-glow"></div>
        <div class="svc-inner">
          <div class="svc-num">04</div>
          <div class="svc-body">
            <h3>AI & Automation</h3>
            <p>Intelligent workflows powered by Claude and GPT. Automate support, content, documents, and operational decisions.</p>
            <!-- AI routing canvas demo -->
            <div class="ai-demo-wrap" id="svc-ai-demo">
              <div class="ai-prompt-row">
                <span class="ai-prompt-icon">›</span>
                <span class="ai-type-text"></span>
                <span class="ai-cursor">▋</span>
              </div>
              <canvas class="ai-canvas" id="ai-route-canvas"></canvas>
            </div>
            <div class="svc-tags"><span>Claude API</span><span>GPT</span><span>Pipelines</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-diamond" style="background:rgba(196,122,232,0.1)"></div>
      </div>

      <div class="svc-card svc-wide tilt-card" style="--bg:#0F2E18;--accent:#4DC878;--num-c:rgba(77,200,120,0.08)">
        <div class="tilt-glow"></div>
        <div class="svc-inner">
          <div class="svc-num">05</div>
          <div class="svc-body">
            <h3>Business Websites</h3>
            <p>Fast, mobile-first websites with WhatsApp booking, Google Maps, and near-zero operating costs. Live in 12 days. You own everything.</p>
            <!-- Browser mockup demo -->
            <div class="biz-demo" id="svc-biz-demo">
              <div class="biz-browser">
                <div class="biz-chrome">
                  <div class="biz-dots"><span></span><span></span><span></span></div>
                  <div class="biz-url">corpdrive.in</div>
                  <div class="biz-chrome-actions"><span class="biz-ssl">🔒</span></div>
                </div>
                <div class="biz-screen">
                  <!-- Page sections that cycle -->
                  <div class="biz-page biz-page-active" data-page="home">
                    <div class="biz-nav">
                      <span class="biz-brand">CorpDrive</span>
                      <div class="biz-nav-links"><span>Fleet</span><span>Pricing</span><span class="biz-nav-cta">Get Quote</span></div>
                    </div>
                    <div class="biz-hero">
                      <div class="biz-hero-label">B2B Fleet Management</div>
                      <div class="biz-hero-h1">Move your<br/><em>business forward</em></div>
                      <div class="biz-hero-btns">
                        <span class="biz-btn-primary">Book a Demo</span>
                        <span class="biz-btn-ghost">View Fleet →</span>
                      </div>
                    </div>
                    <div class="biz-stats-bar">
                      <div class="biz-stat"><span class="biz-sv">500+</span><span class="biz-sl">Vehicles</span></div>
                      <div class="biz-stat"><span class="biz-sv">12 Cities</span><span class="biz-sl">Coverage</span></div>
                      <div class="biz-stat"><span class="biz-sv">98%</span><span class="biz-sl">On-time</span></div>
                    </div>
                  </div>
                  <div class="biz-page" data-page="fleet">
                    <div class="biz-nav">
                      <span class="biz-brand">CorpDrive</span>
                      <div class="biz-nav-links"><span class="biz-nav-active">Fleet</span><span>Pricing</span><span class="biz-nav-cta">Get Quote</span></div>
                    </div>
                    <div class="biz-fleet-section">
                      <div class="biz-section-label">Our Fleet</div>
                      <div class="biz-fleet-grid">
                        <div class="biz-fleet-card"><div class="biz-fleet-img"></div><div class="biz-fleet-name">Sedan</div><div class="biz-fleet-cap">4 seats</div></div>
                        <div class="biz-fleet-card"><div class="biz-fleet-img biz-fleet-suv"></div><div class="biz-fleet-name">SUV</div><div class="biz-fleet-cap">7 seats</div></div>
                        <div class="biz-fleet-card"><div class="biz-fleet-img biz-fleet-van"></div><div class="biz-fleet-name">Van</div><div class="biz-fleet-cap">12 seats</div></div>
                      </div>
                    </div>
                  </div>
                  <div class="biz-page" data-page="contact">
                    <div class="biz-nav">
                      <span class="biz-brand">CorpDrive</span>
                      <div class="biz-nav-links"><span>Fleet</span><span>Pricing</span><span class="biz-nav-cta">Get Quote</span></div>
                    </div>
                    <div class="biz-contact-section">
                      <div class="biz-section-label">Get in Touch</div>
                      <div class="biz-contact-row">
                        <div class="biz-input-block"><div class="biz-input-label">Company name</div><div class="biz-input-field"></div></div>
                        <div class="biz-input-block"><div class="biz-input-label">Fleet size needed</div><div class="biz-input-field"></div></div>
                      </div>
                      <div class="biz-whatsapp-btn"><span>💬</span> Chat on WhatsApp</div>
                    </div>
                  </div>
                </div>
                <div class="biz-page-dots">
                  <span class="biz-pdot biz-pdot-active" data-target="home"></span>
                  <span class="biz-pdot" data-target="fleet"></span>
                  <span class="biz-pdot" data-target="contact"></span>
                </div>
              </div>
              <div class="biz-side">
                <div class="biz-side-stat"><span class="biz-side-val">12</span><span class="biz-side-lbl">Days to launch</span></div>
                <div class="biz-side-stat"><span class="biz-side-val">~₹0</span><span class="biz-side-lbl">Monthly hosting</span></div>
                <div class="biz-feat-list">
                  <div class="biz-feat"><span class="biz-feat-dot" style="background:#4DC878"></span>WhatsApp booking</div>
                  <div class="biz-feat"><span class="biz-feat-dot" style="background:#4DC878"></span>Google Maps embed</div>
                  <div class="biz-feat"><span class="biz-feat-dot" style="background:#4DC878"></span>100% yours</div>
                </div>
              </div>
            </div>
            <div class="svc-tags"><span>Astro</span><span>Netlify</span><span>WhatsApp</span><span>12 Days</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-square" style="background:rgba(77,200,120,0.08)"></div>
      </div>

      <div class="svc-card svc-tall tilt-card" style="--bg:#2E2206;--accent:#E8C84A;--num-c:rgba(232,200,74,0.08)">
        <div class="tilt-glow"></div>
        <div class="svc-inner">
          <div class="svc-num">06</div>
          <div class="svc-body">
            <h3>Custom Software</h3>
            <p>Bespoke backend systems, REST APIs, admin panels, and data pipelines. If your business has a workflow, we can automate it.</p>
            <div class="svc-tags"><span>Java</span><span>Node.js</span><span>APIs</span></div>
          </div>
        </div>
        <div class="svc-deco svc-deco-circle" style="background:rgba(232,200,74,0.08)"></div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════ STATS ══════════════ -->
<section id="stats" class="stats-section">
  <div class="container">
    <div class="stats-grid" id="stats-grid">
      <!-- Vertical border lines (hidden, revealed by GSAP scaleY) -->
      <div class="stat-vline" id="svl-1" aria-hidden="true"></div>
      <div class="stat-vline" id="svl-2" aria-hidden="true"></div>
      <div class="stat-vline" id="svl-3" aria-hidden="true"></div>
      <!-- Horizontal border lines -->
      <div class="stat-hline" id="shl-top" aria-hidden="true"></div>
      <div class="stat-hline" id="shl-bot" aria-hidden="true"></div>

      <div class="stat-big">
        <p class="stat-num" data-counter="15" data-suffix="">15</p>
        <p class="stat-unit">days</p>
        <p class="stat-desc">Average delivery from brief to live product</p>
      </div>
      <div class="stat-big">
        <p class="stat-num" data-counter="100" data-suffix="%">100%</p>
        <p class="stat-desc">Code ownership transferred — no lock-in, ever</p>
      </div>
      <div class="stat-big">
        <p class="stat-num" data-counter="3" data-suffix="+">3+</p>
        <p class="stat-desc">Products live in production and growing</p>
      </div>
      <div class="stat-big">
        <p class="stat-num" data-counter="6" data-suffix="">6</p>
        <p class="stat-desc">Service verticals across mobile, web, AI, and cloud</p>
      </div>
    </div>

    <div class="charts-row">
      <!-- Donut: pure SVG for stroke-dashoffset control -->
      <div class="chart-block" id="chart-block-donut">
        <p class="chart-label">Technology split</p>
        <div class="chart-donut-wrap">
          <svg id="svg-donut" viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Track ring -->
            <circle cx="80" cy="80" r="58" stroke="rgba(245,239,228,0.05)" stroke-width="22" fill="none"/>
            <!-- Segments: circumference = 2π×58 ≈ 364.4
                 Mobile 30% = 109.3, Backend 25% = 91.1, Web 25% = 91.1, AI 20% = 72.9
                 Each segment offset = sum of prior segments, starting from top (-90°) via rotate(-90) -->
            <circle id="ds-mobile"  cx="80" cy="80" r="58" stroke="#C9A96E" stroke-width="22" fill="none" stroke-linecap="butt"
              stroke-dasharray="109.3 364.4" stroke-dashoffset="364.4" transform="rotate(-90 80 80)"/>
            <circle id="ds-backend" cx="80" cy="80" r="58" stroke="#E8865A" stroke-width="22" fill="none" stroke-linecap="butt"
              stroke-dasharray="91.1 364.4"  stroke-dashoffset="364.4" transform="rotate(-90 80 80)"/>
            <circle id="ds-web"     cx="80" cy="80" r="58" stroke="#6B8AE8" stroke-width="22" fill="none" stroke-linecap="butt"
              stroke-dasharray="91.1 364.4"  stroke-dashoffset="364.4" transform="rotate(-90 80 80)"/>
            <circle id="ds-ai"      cx="80" cy="80" r="58" stroke="#B87AE8" stroke-width="22" fill="none" stroke-linecap="butt"
              stroke-dasharray="72.9 364.4"  stroke-dashoffset="364.4" transform="rotate(-90 80 80)"/>
            <!-- Inner cutout for donut hole feel -->
            <circle cx="80" cy="80" r="47" fill="#1C1814"/>
          </svg>
          <div class="donut-center"><p class="donut-pct" id="donut-pct">0%</p><p class="donut-lbl">Mobile</p></div>
        </div>
        <div class="chart-legend" id="donut-legend">
          <div class="legend-row" style="opacity:0;transform:translateX(-8px)"><span class="ld" style="background:#C9A96E"></span><span>Mobile</span><span class="lv">30%</span></div>
          <div class="legend-row" style="opacity:0;transform:translateX(-8px)"><span class="ld" style="background:#E8865A"></span><span>Backend</span><span class="lv">25%</span></div>
          <div class="legend-row" style="opacity:0;transform:translateX(-8px)"><span class="ld" style="background:#6B8AE8"></span><span>Web</span><span class="lv">25%</span></div>
