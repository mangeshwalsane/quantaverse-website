  .svc-grid { display:grid; grid-template-columns:1fr; gap:1rem; }
  @media(min-width:640px)  { .svc-grid { grid-template-columns:repeat(2,1fr); } }
  @media(min-width:1024px) { .svc-grid { grid-template-columns:repeat(3,1fr); grid-template-rows:auto auto; } .svc-tall { grid-row:span 2; } .svc-wide { grid-column:span 2; } }

  /* Glassmorphic cards — frosted dark glass over the `--bg` color accent */
  .svc-card {
    position:relative; overflow:hidden; border-radius:20px; padding:2.5rem; min-height:280px;
    transform-style:preserve-3d; will-change:transform;
    /* Glass: dark ink base + translucent accent tint + blur */
    background: color-mix(in srgb, var(--bg) 40%, rgba(3,7,18,0.82));
    backdrop-filter: blur(14px) saturate(1.4);
    -webkit-backdrop-filter: blur(14px) saturate(1.4);
    border: 1px solid rgba(255,255,255,0.07);
    box-shadow: 0 4px 32px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.05);
    transition: box-shadow 0.35s, border-color 0.35s, transform 0.35s;
  }
  .svc-card:hover {
    box-shadow: 0 24px 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.1), inset 0 1px 0 rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.14);
  }
  @media(min-width:1024px) { .svc-tall { min-height:auto; } }

  /* Cursor-tracking glow inside glass card */
  .tilt-glow { position:absolute; inset:0; opacity:0; pointer-events:none; background:radial-gradient(circle 220px at var(--mx,50%) var(--my,50%), rgba(255,255,255,0.07), transparent 70%); transition:opacity 0.3s; border-radius:20px; }
  .svc-card:hover .tilt-glow { opacity:1; }

  .svc-inner { position:relative; z-index:var(--z-content); height:100%; display:flex; flex-direction:column; justify-content:space-between; }
