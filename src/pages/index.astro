  /* ── HERO ICON CARD ── */
  .hero-icon-card { display:flex; align-items:center; gap:1rem; background:rgba(245,239,228,0.04); border:1px solid rgba(245,239,228,0.08); border-radius:14px; padding:0.85rem 1.2rem; margin-bottom:1.5rem; width:fit-content; max-width:100%; backdrop-filter:blur(8px); flex-wrap:nowrap; opacity:0; } /* GSAP reveals */
  .hero-icon-row { display:flex; align-items:center; gap:8px; flex-shrink:0; }
