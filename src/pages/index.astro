---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Quantaverse Labs Pvt Ltd builds mobile apps, SaaS platforms, booking systems, AI tools, and custom digital infrastructure for businesses. Build once. Automate forever." />
  <meta property="og:title" content="Quantaverse Labs — We design, build, and automate digital businesses." />
  <meta property="og:description" content="Custom mobile apps, SaaS, booking systems, AI tools. Build once. Automate forever." />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#1C1917" />
  <title>Quantaverse Labs — We design, build, and automate digital businesses.</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

<!-- GRAIN OVERLAY -->
<div class="grain" aria-hidden="true"></div>

<!-- ══════════════════════════════════════════
     NAV
══════════════════════════════════════════ -->
<nav id="nav" class="px-6 md:px-12 lg:px-20">
  <div class="max-w-7xl mx-auto flex items-center justify-between h-20">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0">
      <svg width="160" height="44" viewBox="0 0 160 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(0, 2)">
          <rect x="2" y="9" width="18" height="18" rx="1.2" stroke="#C9A96E" stroke-width="1.1" transform="rotate(45 11 18)" fill="none"/>
          <rect x="5.5" y="12.5" width="11" height="11" rx="0.8" stroke="#C9A96E" stroke-width="0.7" opacity="0.4" transform="rotate(45 11 18)" fill="none"/>
          <rect x="8" y="15" width="6" height="6" rx="0.4" fill="#C9A96E" opacity="0.85" transform="rotate(45 11 18)"/>
        </g>
        <text x="35" y="19" font-family="'DM Sans', sans-serif" font-size="11" font-weight="600" letter-spacing="2.5" fill="#F5EFE4">QUANTAVERSE</text>
        <text x="35" y="34" font-family="'DM Sans', sans-serif" font-size="8.5" font-weight="300" letter-spacing="4.5" fill="#C9A96E">LABS  PVT  LTD</text>
      </svg>
    </a>
    <!-- Nav Links -->
    <div class="hidden md:flex items-center gap-10">
      <a href="#services" class="text-xs tracking-widest uppercase text-white/40 hover:text-[#C9A96E] transition-colors duration-300">Services</a>
      <a href="#work" class="text-xs tracking-widest uppercase text-white/40 hover:text-[#C9A96E] transition-colors duration-300">Work</a>
      <a href="#about" class="text-xs tracking-widest uppercase text-white/40 hover:text-[#C9A96E] transition-colors duration-300">About</a>
      <a href="#contact" class="btn-primary text-xs py-3 px-7">Start a Project</a>
    </div>
    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
      <span class="w-6 h-px bg-[#F5EFE4] block transition-all duration-300"></span>
      <span class="w-4 h-px bg-[#C9A96E] block transition-all duration-300"></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div id="mobile-menu" class="fixed inset-0 z-50 bg-[#1C1917] flex flex-col items-center justify-center gap-10 opacity-0 pointer-events-none transition-opacity duration-300">
  <button id="mobile-close" class="absolute top-8 right-8 text-white/40 hover:text-white" aria-label="Close">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M6 6L18 18M6 18L18 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
  </button>
  <a href="#services" class="mobile-link font-serif text-5xl font-light text-[#F5EFE4] hover:text-[#C9A96E] transition-colors">Services</a>
  <a href="#work" class="mobile-link font-serif text-5xl font-light text-[#F5EFE4] hover:text-[#C9A96E] transition-colors">Work</a>
  <a href="#about" class="mobile-link font-serif text-5xl font-light text-[#F5EFE4] hover:text-[#C9A96E] transition-colors">About</a>
  <a href="#contact" class="mobile-link font-serif text-5xl font-light text-[#F5EFE4] hover:text-[#C9A96E] transition-colors">Contact</a>
</div>


<!-- ══════════════════════════════════════════
     HERO
══════════════════════════════════════════ -->
<section id="hero" class="relative min-h-screen flex flex-col justify-center overflow-hidden">
  <!-- Three.js canvas -->
  <canvas id="hero-canvas"></canvas>

  <!-- Glows -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full pointer-events-none"
       style="background: radial-gradient(circle, rgba(201,169,110,0.06), transparent 70%); transform: translate(30%,-30%)"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full pointer-events-none"
       style="background: radial-gradient(circle, rgba(196,113,74,0.05), transparent 70%); transform: translate(-30%,30%)"></div>

  <!-- Content -->
  <div class="relative z-10 px-6 md:px-12 lg:px-20 max-w-7xl mx-auto w-full pt-32 pb-24">
    <div class="max-w-4xl">
      <div class="eyebrow mb-8 reveal">
        <div class="eyebrow-line"></div>
        <span>Digital Infrastructure Studio</span>
      </div>

      <h1 class="font-serif text-[clamp(48px,8vw,96px)] font-light leading-[1.02] text-[#F5EFE4] mb-8 reveal" style="transition-delay:0.1s">
        We design, build,<br/>
        and <em style="font-style:italic;color:#C9A96E">automate</em><br/>
        digital businesses.
      </h1>

      <p class="text-sm md:text-base font-light text-white/45 leading-relaxed max-w-xl mb-14 reveal" style="transition-delay:0.2s">
        From fitness marketplaces and mobile apps to booking engines, SaaS platforms, and AI-powered workflows — we create software that removes manual operations and scales efficiently.
      </p>

      <div class="flex flex-wrap gap-4 reveal" style="transition-delay:0.3s">
        <a href="#contact" class="btn-primary">
          Start a Project
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        </a>
        <a href="#work" class="btn-outline">See Our Work</a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 reveal" style="transition-delay:0.5s">
      <div class="w-px h-12 overflow-hidden" style="background:rgba(245,239,228,0.1)">
        <div id="scroll-line" class="w-full bg-[#C9A96E]" style="height:50%;animation:scrollDrop 1.8s ease-in-out infinite"></div>
      </div>
      <span class="text-[10px] tracking-[0.4em] uppercase text-white/25">Scroll</span>
    </div>
  </div>

  <!-- Stats bar at bottom -->
  <div class="relative z-10 border-t border-white/5 px-6 md:px-12 lg:px-20">
    <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4">
      <div class="py-8 pr-8 border-r border-white/5 reveal">
        <p class="font-serif text-4xl font-light text-[#C9A96E] mb-1" data-count="15">15</p>
        <p class="text-[10px] tracking-widest uppercase text-white/35">Days to Live</p>
      </div>
      <div class="py-8 px-8 border-r border-white/5 reveal" style="transition-delay:0.1s">
        <p class="font-serif text-4xl font-light text-[#C9A96E] mb-1" data-count="3">3</p>
        <p class="text-[10px] tracking-widest uppercase text-white/35">Products Shipped</p>
      </div>
      <div class="py-8 px-8 border-r border-white/5 reveal" style="transition-delay:0.2s">
        <p class="font-serif text-4xl font-light text-[#C9A96E] mb-1">100%</p>
        <p class="text-[10px] tracking-widest uppercase text-white/35">Code Ownership</p>
      </div>
      <div class="py-8 pl-8 reveal" style="transition-delay:0.3s">
        <p class="font-serif text-4xl font-light text-[#C9A96E] mb-1">₹0</p>
        <p class="text-[10px] tracking-widest uppercase text-white/35">Platform Lock-in</p>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════
     SERVICES
══════════════════════════════════════════ -->
<section id="services" class="section py-32 px-6 md:px-12 lg:px-20">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-8">
      <div>
        <div class="eyebrow mb-6 reveal"><div class="eyebrow-line"></div><span>What We Do</span></div>
        <h2 class="font-serif text-[clamp(36px,5vw,64px)] font-light text-[#F5EFE4] leading-tight reveal" style="transition-delay:0.1s">
          Full-spectrum digital<br/>
          <em style="font-style:italic;color:#C9A96E">infrastructure</em>
        </h2>
      </div>
      <p class="text-sm text-white/40 leading-relaxed max-w-sm reveal" style="transition-delay:0.2s">
        We don't hand you a template. Every product is engineered from scratch — built to work autonomously so you can focus on running your business.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white/5">

      <!-- Card 1 -->
      <div class="service-card bg-[#1C1917] p-10 reveal">
        <div class="mb-6 w-10 h-10 border border-[rgba(201,169,110,0.25)] flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="3" y="2" width="14" height="16" rx="1.5" stroke="#C9A96E" stroke-width="1.2"/>
            <rect x="6" y="6" width="8" height="1" rx="0.5" fill="#C9A96E" opacity="0.6"/>
            <rect x="6" y="9" width="6" height="1" rx="0.5" fill="#C9A96E" opacity="0.4"/>
            <circle cx="10" cy="13.5" r="1.5" stroke="#C9A96E" stroke-width="0.9"/>
          </svg>
        </div>
        <p class="text-[10px] tracking-widest uppercase text-[#C9A96E] mb-3">01</p>
        <h3 class="font-serif text-2xl font-light text-[#F5EFE4] mb-4">Mobile Apps</h3>
        <p class="text-sm text-white/40 leading-relaxed">
          iOS and Android apps built with Flutter — one codebase, two stores. From consumer marketplaces to B2B tools, we ship production-grade apps with real backend integrations.
        </p>
        <div class="mt-8 flex flex-wrap gap-2">
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Flutter</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">iOS</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Android</span>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="service-card bg-[#1C1917] p-10 reveal" style="transition-delay:0.05s">
        <div class="mb-6 w-10 h-10 border border-[rgba(201,169,110,0.25)] flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="2" y="2" width="16" height="16" rx="1.5" stroke="#C9A96E" stroke-width="1.2"/>
            <path d="M2 7H18" stroke="#C9A96E" stroke-width="0.8" opacity="0.4"/>
            <circle cx="5" cy="4.5" r="0.8" fill="#C9A96E" opacity="0.6"/>
            <circle cx="8" cy="4.5" r="0.8" fill="#C9A96E" opacity="0.4"/>
            <path d="M6 11L8.5 13.5L14 9" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="text-[10px] tracking-widest uppercase text-[#C9A96E] mb-3">02</p>
        <h3 class="font-serif text-2xl font-light text-[#F5EFE4] mb-4">Booking & Payment Platforms</h3>
        <p class="text-sm text-white/40 leading-relaxed">
          End-to-end booking systems with real-time availability, Razorpay/Stripe payments, automated confirmations, and calendar sync. No manual follow-ups.
        </p>
        <div class="mt-8 flex flex-wrap gap-2">
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Razorpay</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Calendar</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Webhooks</span>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="service-card bg-[#1C1917] p-10 reveal" style="transition-delay:0.1s">
        <div class="mb-6 w-10 h-10 border border-[rgba(201,169,110,0.25)] flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="10" r="8" stroke="#C9A96E" stroke-width="1.2"/>
            <path d="M10 6V10L13 12" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/>
            <circle cx="10" cy="10" r="1.5" fill="#C9A96E" opacity="0.7"/>
          </svg>
        </div>
        <p class="text-[10px] tracking-widest uppercase text-[#C9A96E] mb-3">03</p>
        <h3 class="font-serif text-2xl font-light text-[#F5EFE4] mb-4">SaaS Platforms</h3>
        <p class="text-sm text-white/40 leading-relaxed">
          Multi-tenant SaaS products with subscription billing, role-based access, admin dashboards, and analytics. Built to scale from 10 to 10,000 users without re-architecting.
        </p>
        <div class="mt-8 flex flex-wrap gap-2">
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Spring Boot</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">PostgreSQL</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">AWS</span>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="service-card bg-[#1C1917] p-10 reveal" style="transition-delay:0.15s">
        <div class="mb-6 w-10 h-10 border border-[rgba(201,169,110,0.25)] flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 14L8 9L11 12L14 7L16 10" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="2" y="2" width="16" height="16" rx="1.5" stroke="#C9A96E" stroke-width="1.2" opacity="0.4"/>
          </svg>
        </div>
        <p class="text-[10px] tracking-widest uppercase text-[#C9A96E] mb-3">04</p>
        <h3 class="font-serif text-2xl font-light text-[#F5EFE4] mb-4">AI Tools & Automation</h3>
        <p class="text-sm text-white/40 leading-relaxed">
          Intelligent workflows powered by Claude, GPT, and custom ML pipelines. Automate customer support, content generation, document processing, and operational decisions.
        </p>
        <div class="mt-8 flex flex-wrap gap-2">
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Claude API</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Automation</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Workflows</span>
        </div>
      </div>

      <!-- Card 5 -->
      <div class="service-card bg-[#1C1917] p-10 reveal" style="transition-delay:0.2s">
        <div class="mb-6 w-10 h-10 border border-[rgba(201,169,110,0.25)] flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="2" y="5" width="16" height="11" rx="1.5" stroke="#C9A96E" stroke-width="1.2"/>
            <path d="M2 8H18" stroke="#C9A96E" stroke-width="0.8" opacity="0.4"/>
            <circle cx="5" cy="6.5" r="0.7" fill="#C9A96E" opacity="0.6"/>
            <circle cx="7.5" cy="6.5" r="0.7" fill="#C9A96E" opacity="0.4"/>
            <rect x="5" y="11" width="5" height="1" rx="0.5" fill="#C9A96E" opacity="0.5"/>
            <rect x="5" y="13.5" width="3" height="1" rx="0.5" fill="#C9A96E" opacity="0.3"/>
          </svg>
        </div>
        <p class="text-[10px] tracking-widest uppercase text-[#C9A96E] mb-3">05</p>
        <h3 class="font-serif text-2xl font-light text-[#F5EFE4] mb-4">Business Websites</h3>
        <p class="text-sm text-white/40 leading-relaxed">
          Fast, mobile-first business websites with WhatsApp booking, Google Maps integration, and near-zero operating costs. Live in 12 days. You own everything.
        </p>
        <div class="mt-8 flex flex-wrap gap-2">
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Astro</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Netlify</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">WhatsApp</span>
        </div>
      </div>

      <!-- Card 6 -->
      <div class="service-card bg-[#1C1917] p-10 reveal" style="transition-delay:0.25s">
        <div class="mb-6 w-10 h-10 border border-[rgba(201,169,110,0.25)] flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M7 4L4 10L7 16" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M13 4L16 10L13 16" stroke="#C9A96E" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M9.5 3L10.5 17" stroke="#C9A96E" stroke-width="0.8" opacity="0.4" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="text-[10px] tracking-widest uppercase text-[#C9A96E] mb-3">06</p>
        <h3 class="font-serif text-2xl font-light text-[#F5EFE4] mb-4">Custom Software</h3>
        <p class="text-sm text-white/40 leading-relaxed">
          Bespoke backend systems, REST APIs, admin panels, and data pipelines tailored to your exact process. If your business has a workflow, we can automate it.
        </p>
        <div class="mt-8 flex flex-wrap gap-2">
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Java</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">Node.js</span>
          <span class="text-[10px] tracking-wider uppercase text-white/25 border border-white/8 px-3 py-1">APIs</span>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════
     HOW WE WORK
══════════════════════════════════════════ -->
<section id="process" class="section py-32 px-6 md:px-12 lg:px-20 border-t border-white/5">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">

      <!-- Left -->
      <div>
        <div class="eyebrow mb-6 reveal"><div class="eyebrow-line"></div><span>How We Work</span></div>
        <h2 class="font-serif text-[clamp(36px,4vw,56px)] font-light text-[#F5EFE4] leading-tight mb-8 reveal" style="transition-delay:0.1s">
          From brief to<br/>
          <em style="font-style:italic;color:#C9A96E">live product</em><br/>
          in 15 days.
        </h2>
        <p class="text-sm text-white/40 leading-relaxed mb-12 reveal" style="transition-delay:0.2s">
          No discovery phases that stretch into months. No surprise billing. We move fast because we've built systems like yours before.
        </p>
        <a href="#contact" class="btn-primary reveal" style="transition-delay:0.3s">
          Let's Talk
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        </a>
      </div>

      <!-- Right: Process Steps -->
      <div class="relative pl-12">
        <div class="process-line absolute left-5 top-6 bottom-6 w-px"
             style="background:linear-gradient(to bottom, rgba(201,169,110,0.3), rgba(201,169,110,0.05))"></div>

        <div class="space-y-12">
          <div class="relative reveal">
            <div class="absolute -left-12 top-0 w-10 h-10 rounded-full bg-[#2A2320] border border-[rgba(201,169,110,0.3)] flex items-center justify-center z-10">
              <span class="font-sans text-xs font-500 text-[#C9A96E]">01</span>
            </div>
            <p class="text-[10px] tracking-widest uppercase text-[#C4714A] mb-2">Days 1–3</p>
            <h3 class="font-serif text-2xl font-light text-[#F5EFE4] mb-3">Discover & Design</h3>
            <p class="text-sm text-white/40 leading-relaxed">We map your full workflow, decide the right stack, and finalize UI direction. You sign off on wireframes before a single line of code is written.</p>
          </div>

          <div class="relative reveal" style="transition-delay:0.1s">
            <div class="absolute -left-12 top-0 w-10 h-10 rounded-full bg-[#2A2320] border border-[rgba(201,169,110,0.3)] flex items-center justify-center z-10">
              <span class="font-sans text-xs font-500 text-[#C9A96E]">02</span>
            </div>
            <p class="text-[10px] tracking-widest uppercase text-[#C4714A] mb-2">Days 4–12</p>
            <h3 class="font-serif text-2xl font-light text-[#F5EFE4] mb-3">Build & Integrate</h3>
            <p class="text-sm text-white/40 leading-relaxed">Full-stack development: frontend, backend, payments, automations, email flows. Daily progress updates. You watch it being built.</p>
          </div>

          <div class="relative reveal" style="transition-delay:0.2s">
            <div class="absolute -left-12 top-0 w-10 h-10 rounded-full bg-[#2A2320] border border-[rgba(201,169,110,0.3)] flex items-center justify-center z-10">
              <span class="font-sans text-xs font-500 text-[#C9A96E]">03</span>
            </div>
            <p class="text-[10px] tracking-widest uppercase text-[#C4714A] mb-2">Day 13–15</p>
            <h3 class="font-serif text-2xl font-light text-[#F5EFE4] mb-3">Deploy & Hand Off</h3>
            <p class="text-sm text-white/40 leading-relaxed">We deploy to your domain, configure your DNS, and hand over full source code and credentials. You own everything — no lock-in, no monthly fee.</p>
          </div>

          <div class="relative reveal" style="transition-delay:0.3s">
