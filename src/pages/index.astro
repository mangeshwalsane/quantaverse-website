  .svc-body h3 { font-size:clamp(18px,2vw,26px); font-weight:700; color:var(--cream); margin-bottom:0.85rem; line-height:1.2; }
  /* Fluid body text using clamp — WCAG AA: min 12px, comfortable 13-14px */
  .svc-body p  { font-size:clamp(12px,1.1vw,14px); color:rgba(245,239,228,0.52); line-height:1.8; margin-bottom:1.5rem; }
  .svc-tags { display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:auto; }
  .svc-tags span { font-size:10px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:var(--accent); border:1px solid var(--accent); border-radius:100px; padding:4px 12px; opacity:0.75; transition:opacity 0.2s,background 0.2s,color 0.2s; }
  .svc-card:hover .svc-tags span { opacity:1; }

  .svc-deco { position:absolute; z-index:1; pointer-events:none; }
  .svc-deco-circle { width:260px; height:260px; border-radius:50%; right:-5rem; bottom:-5rem; }
  .svc-deco-ring   { width:280px; height:280px; border-radius:50%; border:36px solid; right:-6rem; bottom:-6rem; background:transparent !important; }
  .svc-deco-pill   { width:120px; height:280px; border-radius:100px; right:-2rem; bottom:-4rem; transform:rotate(-20deg); }
  .svc-deco-diamond{ width:160px; height:160px; transform:rotate(45deg); right:-4rem; bottom:-4rem; border-radius:16px; }
  .svc-deco-square { width:220px; height:220px; border-radius:28px; right:-3rem; bottom:-4rem; transform:rotate(12deg); }

  /* ── STATS ── */
  .stats-section { padding:7rem 0; background:var(--ink-3); }
  /* Grid uses overlay lines instead of gap background for animatable borders */
  .stats-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:0; margin-bottom:4rem; position:relative; }
  @media(min-width:768px) { .stats-grid { grid-template-columns:repeat(4,1fr); } }
  .stat-big  { background:var(--ink-3); padding:3rem 2rem; }
  /* Animated border lines — vertical (scaleY from center) */
  .stat-vline { position:absolute; top:0; width:1px; height:100%; background:rgba(245,239,228,0.08); transform:scaleY(0); transform-origin:center; pointer-events:none; will-change:transform; }
  #svl-1 { left:50%; }
  #svl-2 { left:25%; display:none; }
  #svl-3 { left:75%; display:none; }
  @media(min-width:768px) { #svl-2 { display:block; } #svl-3 { display:block; } #svl-1 { left:25%; } }
  /* Horizontal border lines (scaleX from left) */
  .stat-hline { position:absolute; left:0; width:100%; height:1px; background:rgba(245,239,228,0.08); transform:scaleX(0); transform-origin:left; pointer-events:none; will-change:transform; }
  #shl-top { top:0; }
  #shl-bot { bottom:0; }
  /* Radar SVG wrap */
  .radar-wrap { display:flex; justify-content:center; }
  .radar-wrap svg { width:100%; max-width:220px; height:auto; }
  .stat-num  { font-family:'Plus Jakarta Sans',sans-serif; font-size:clamp(48px,7vw,88px); font-weight:800; background:linear-gradient(135deg,#C9A96E,#E8865A); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; line-height:1; letter-spacing:-0.03em; }
  .stat-unit { font-size:14px; color:rgba(201,169,110,0.5); margin-top:0.25rem; margin-bottom:0.75rem; }
  .stat-desc { font-size:12px; color:rgba(245,239,228,0.3); line-height:1.6; }

  .charts-row { display:grid; grid-template-columns:1fr; gap:1.5rem; }
  @media(min-width:768px) { .charts-row { grid-template-columns:1fr 2fr 1fr; } }
  .chart-block { background:#1C1814; border:1px solid rgba(245,239,228,0.06); padding:2rem; border-radius:12px; min-width:0; }
  .chart-label { font-size:10px; letter-spacing:0.3em; text-transform:uppercase; color:rgba(201,169,110,0.6); margin-bottom:1.25rem; display:block; }
  .chart-donut-wrap { position:relative; max-width:160px; margin:0 auto 1.5rem; }
  .chart-donut-wrap canvas { width:100% !important; height:auto !important; }
  .donut-center { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); text-align:center; }
  .donut-pct { font-family:'Plus Jakarta Sans',sans-serif; font-size:1.5rem; font-weight:700; color:#C9A96E; line-height:1; }
  .donut-lbl { font-size:9px; letter-spacing:0.25em; text-transform:uppercase; color:rgba(245,239,228,0.3); }
  .chart-legend { display:flex; flex-direction:column; gap:0.5rem; }
  .legend-row { display:flex; align-items:center; gap:0.5rem; font-size:11px; color:rgba(245,239,228,0.4); }
  .ld { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .lv { margin-left:auto; }
  .chart-block-wide canvas { width:100% !important; height:180px !important; }
  .chart-block:last-child canvas { width:100% !important; height:auto !important; max-width:220px; display:block; margin:0 auto; }

  /* ── PROCESS — 15-day timeline ── */
  .process-section { background:#F2EAD8; padding:7rem 0; }
  .process-header { margin-bottom:4rem; }
  .process-h2 { font-size:clamp(32px,4.2vw,60px); font-weight:800; line-height:1.1; color:#1A1410; margin-bottom:1.25rem; letter-spacing:-0.02em; }
  .process-h2 em { font-style:italic; font-weight:300; color:#8C6B3E; }
  .process-sub { font-size:clamp(13px,1.1vw,15px); color:#5A4A38; line-height:1.75; max-width:500px; }

  /* Two-column layout: phase cards left, day timeline right */
  .process-layout { display:grid; grid-template-columns:1fr; gap:3rem; }
  @media(min-width:1024px) { .process-layout { grid-template-columns:1fr 1fr; gap:5rem; align-items:start; } }

  /* Phase summary cards */
  .process-phases-col { display:flex; flex-direction:column; gap:1.25rem; }
  .process-phase-card {
    background:#fff; border-radius:20px; padding:2rem 2.25rem;
    border-left:3px solid var(--pc);
    box-shadow:0 2px 24px rgba(26,20,16,0.06);
    transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s;
  }
  .process-phase-card:hover { transform:translateX(6px); box-shadow:0 8px 40px rgba(26,20,16,0.1); }
  .process-phase-card-dark { background:#1A1410; }
  .ppc-header { display:flex; align-items:center; gap:10px; margin-bottom:0.75rem; }
  .ppc-dot { width:8px; height:8px; border-radius:50%; background:var(--pc); flex-shrink:0; box-shadow:0 0 8px var(--pc); }
  .ppc-range { font-size:10px; letter-spacing:0.3em; text-transform:uppercase; color:var(--pc); font-weight:500; }
  .ppc-title { font-size:clamp(15px,1.4vw,18px); font-weight:700; color:#1A1410; margin-bottom:0.6rem; }
  .process-phase-card-dark .ppc-title { color:#F5EFE4; }
  .ppc-desc { font-size:clamp(12px,1vw,13px); color:#5A4A38; line-height:1.75; }
  .process-phase-card-dark .ppc-desc { color:rgba(245,239,228,0.4); }

  /* Right: vertical day-node timeline */
  .process-timeline-col { position:relative; }
  .tl-wrap { position:relative; padding-left:28px; }

  /* SVG track behind nodes */
  .tl-svg {
    position:absolute; left:2px; top:8px;
    width:4px; height:calc(100% - 16px);
    overflow:visible;
  }
  #tl-fill { stroke-dasharray:560; stroke-dashoffset:560; }

  /* Nodes list */
  .tl-nodes { display:flex; flex-direction:column; gap:0; }
  .tl-node {
    display:flex; align-items:flex-start; gap:14px;
    padding:10px 0;
    opacity:0.22;
    transform:translateX(-6px);
    transition:opacity 0.45s, transform 0.45s, color 0.3s;
  }
  .tl-node.lit { opacity:1; transform:translateX(0); }
  .tl-dot {
    width:8px; height:8px; border-radius:50; flex-shrink:0;
    border-radius:50%; margin-top:4px;
    background:var(--nc);
    transition:box-shadow 0.4s;
  }
  .tl-node.lit .tl-dot { box-shadow:0 0 8px 3px var(--nc); }
  .tl-label { font-size:clamp(12px,1vw,13px); color:#1A1410; line-height:1.4; }
  .tl-label em { display:block; font-style:normal; font-size:9px; letter-spacing:0.2em; text-transform:uppercase; color:var(--nc); margin-bottom:2px; font-weight:600; }

  /* ── WORK ── */
  /* ── INDUSTRIES ─────────────────────────────────────────── */
  .ind-section { padding:7rem 0; background:var(--ink-1); }
  .ind-header  { margin-bottom:4rem; }
  .ind-h2 { font-family:'Cormorant Garamond',serif; font-size:clamp(36px,4.5vw,68px); font-weight:300; color:var(--cream); line-height:1.1; margin:0.5rem 0 1rem; letter-spacing:-0.01em; }
  .ind-h2 em { font-style:italic; color:var(--gold); }
  .ind-sub { font-size:clamp(13px,1.1vw,15px); color:rgba(245,239,228,0.45); line-height:1.75; max-width:520px; }

  /* Fluid grid — auto-fill, min 220px, scales 1→2→3→5 cols */
  .ind-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1px;
    background: rgba(245,239,228,0.05);
    border: 1px solid rgba(245,239,228,0.05);
    border-radius: 16px;
    overflow: hidden;
  }

  .ind-card {
    position: relative;
    background: var(--ink-1);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    /* start hidden — GSAP animates in */
    opacity: 0;
    transform: translateY(28px) scale(0.94);
    will-change: transform, opacity;
    transition: box-shadow 0.3s, background 0.3s;
    overflow: hidden;
  }
  .ind-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle 180px at var(--mx,50%) var(--my,50%), rgba(201,169,110,0.06), transparent 70%);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }
  .ind-card:hover::before { opacity: 1; }
  .ind-card:hover {
    background: color-mix(in srgb, var(--ink-1) 85%, rgba(201,169,110,0.15));
    box-shadow: 0 0 0 1px rgba(201,169,110,0.12) inset;
    z-index: 1;
  }
  /* Hover lift — JS adds/removes class for hardware-accel translateY */
  .ind-card.hovered {
    transform: translateY(-5px) scale(1.01) !important;
    box-shadow: 0 16px 40px rgba(0,0,0,0.4), 0 0 0 1px rgba(201,169,110,0.12) inset;
  }

  .ind-emoji {
    font-size: 2rem;
    line-height: 1;
    display: inline-block;
    will-change: transform;
    transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1);
  }
  .ind-card.hovered .ind-emoji {
    transform: scale(1.22) rotate(-4deg);
  }

  .ind-title {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(13px, 1.1vw, 15px);
    font-weight: 600;
    color: var(--cream);
    line-height: 1.3;
    margin: 0;
  }
  .ind-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }
  .ind-features li {
    font-size: 11px;
    color: rgba(245,239,228,0.38);
    padding-left: 0.9rem;
    position: relative;
    line-height: 1.5;
  }
  .ind-features li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: rgba(201,169,110,0.4);
  }

  /* Badge */
  .ind-badge {
    align-self: flex-start;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 100px;
    margin-top: auto;
  }
  .badge-new {
    color: #E8865A;
    border: 1px solid rgba(232,134,90,0.35);
    background: rgba(232,134,90,0.08);
    position: relative;
    overflow: hidden;
  }
  /* Infinite shimmer sweep on .badge-new */
  .badge-new::after {
    content: '';
    position: absolute;
    top: 0; left: -100%; width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(232,134,90,0.45), transparent);
    animation: badge-sweep 2.4s linear infinite;
  }
  @keyframes badge-sweep {
    0%   { left: -60%; }
    100% { left: 160%; }
  }

  /* CTA card variant */
  .ind-card-cta {
    background: color-mix(in srgb, var(--ink-1) 60%, rgba(201,169,110,0.08));
    border: 1px solid rgba(201,169,110,0.12);
  }
  .ind-card-cta .ind-emoji { color: var(--gold); }
  .ind-cta-desc {
    font-size: 12px;
    color: rgba(245,239,228,0.42);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }
  .ind-cta-btn {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--gold);
    border: 1px solid rgba(201,169,110,0.3);
    border-radius: 100px;
    padding: 6px 16px;
    text-decoration: none;
    transition: background 0.25s, border-color 0.25s;
    align-self: flex-start;
  }
  .ind-cta-btn:hover { background: rgba(201,169,110,0.12); border-color: var(--gold); }

  /* Constellation cursor canvas */
  #cursor-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: calc(var(--z-cursor) - 1);
    will-change: contents;
  }
  @media(hover:none) { #cursor-canvas { display:none; } }

  .work-section { padding:7rem 0; background:#030712; }
  .work-header  { margin-bottom:5rem; }
  .work-h2  { font-size:clamp(36px,5vw,72px); font-weight:800; line-height:1.1; color:#F5EFE4; margin-bottom:1rem; letter-spacing:-0.02em; }
  .work-h2 em { font-style:italic; font-weight:300; }
  .work-sub { font-size:14px; color:rgba(245,239,228,0.35); line-height:1.7; max-width:460px; }

  .work-grid { display:grid; grid-template-columns:1fr; gap:1.5rem; }
  @media(min-width:1024px) { .work-grid { grid-template-columns:1fr 1fr; } }

  .work-card { border-radius:20px; overflow:hidden; transition:transform 0.3s; }
  .work-card:hover { transform:translateY(-6px); }
  .work-card-featured { grid-column:1/-1; display:grid; grid-template-columns:1fr; min-height:480px; background:#1C1814; border:1px solid rgba(245,239,228,0.08); }
  @media(min-width:1024px) { .work-card-featured { grid-template-columns:1fr 1fr; } }

  .wc-info  { padding:3.5rem; display:flex; flex-direction:column; gap:1.25rem; justify-content:center; }
  .wc-badges { display:flex; flex-wrap:wrap; gap:0.75rem; }
  .badge-own  { font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:#C9A96E; border:1px solid rgba(201,169,110,0.35); padding:5px 14px; border-radius:100px; }
  .badge-wip  { display:inline-flex; align-items:center; gap:7px; font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:rgba(232,134,90,0.8); border:1px solid rgba(232,134,90,0.25); padding:5px 14px; border-radius:100px; }
  .badge-client   { font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:rgba(245,239,228,0.35); border:1px solid rgba(245,239,228,0.1); padding:5px 14px; border-radius:100px; }
  .badge-delivery { display:inline-flex; align-items:center; gap:7px; font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:rgba(94,200,122,0.7); border:1px solid rgba(94,200,122,0.2); padding:5px 14px; border-radius:100px; }
  .pulse-dot { display:inline-block; width:6px; height:6px; border-radius:50%; background:#C4714A; animation:pulse 2s ease-in-out infinite; flex-shrink:0; }
  .wc-title   { font-size:clamp(32px,4vw,52px); font-weight:800; color:#F5EFE4; letter-spacing:-0.02em; }
  .wc-desc    { font-size:13px; color:rgba(245,239,228,0.4); line-height:1.8; }
  .wc-tags    { display:flex; flex-wrap:wrap; gap:8px; }
  .wc-tags span { font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:rgba(245,239,228,0.25); border:1px solid rgba(245,239,228,0.08); padding:5px 12px; border-radius:100px; }
  .wc-coming  { font-size:12px; color:rgba(245,239,228,0.48); letter-spacing:0.08em; }
  .wc-visual  { background:#141210; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:3rem; min-height:280px; position:relative; overflow:hidden; }
  .wc-glow    { position:absolute; inset:0; background:radial-gradient(circle at 60% 40%,rgba(18,112,95,0.18),transparent 60%); }
  .wc-wordmark { font-family:'Plus Jakarta Sans',sans-serif; font-size:clamp(48px,8vw,96px); font-weight:800; color:rgba(245,239,228,0.04); position:relative; z-index:1; }
  .wc-modules { display:flex; flex-wrap:wrap; justify-content:center; gap:0.75rem; position:relative; z-index:1; margin:1.25rem 0; }
  .wc-modules span { font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:#12705F; border:1px solid rgba(18,112,95,0.35); padding:6px 14px; border-radius:100px; }
  .wc-caption { font-size:11px; color:rgba(245,239,228,0.18); text-transform:uppercase; letter-spacing:0.1em; position:relative; z-index:1; }
  .work-card-sm { background:var(--wc); padding:3rem; display:flex; flex-direction:column; gap:1.5rem; border:1px solid rgba(255,255,255,0.06); }
  .wcs-top   { display:flex; flex-wrap:wrap; gap:0.75rem; }
  .wcs-title { font-size:2rem; font-weight:700; color:#F5EFE4; letter-spacing:-0.02em; }
  .wcs-desc  { font-size:13px; color:rgba(245,239,228,0.45); line-height:1.8; flex:1; }
  .wcs-tags  { display:flex; flex-wrap:wrap; gap:8px; margin-top:auto; }
  .wcs-tags span { font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:rgba(245,239,228,0.35); border:1px solid rgba(245,239,228,0.15); padding:5px 12px; border-radius:100px; }

  /* ── ABOUT ── */
  .about-section { background:#F2EAD8; padding:7rem 0; }
  .about-grid { display:grid; grid-template-columns:1fr; gap:5rem; }
  @media(min-width:1024px) { .about-grid { grid-template-columns:1fr 1fr; align-items:start; } }
  .about-h2  { font-size:clamp(36px,5vw,68px); font-weight:800; line-height:1.1; color:#1A1410; letter-spacing:-0.02em; margin-bottom:2rem; }
  .about-h2 em { font-style:italic; font-weight:300; color:#8C6B3E; }
  .about-body { display:flex; flex-direction:column; gap:1.25rem; margin-bottom:2.5rem; }
  .about-body p { font-size:14px; color:#5A4A38; line-height:1.85; }
  .about-cta  { display:inline-flex; align-items:center; font-size:14px; font-weight:700; color:#8C6B3E; text-decoration:none; transition:color 0.2s; }
  .about-cta:hover { color:#C9A96E; }
  .about-right { display:flex; flex-direction:column; gap:1.25rem; }
  .value-pill { display:flex; align-items:flex-start; gap:1.25rem; background:var(--vp); padding:1.75rem; border-radius:16px; transition:transform 0.3s; }
  .value-pill:hover { transform:translateX(6px); }
  .vp-icon { width:2.5rem; height:2.5rem; border-radius:50%; background:rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; color:var(--vt); }
  .value-pill h4 { font-size:1rem; font-weight:700; color:#F5EFE4; margin-bottom:0.4rem; }
  .value-pill p  { font-size:12px; color:rgba(245,239,228,0.4); line-height:1.65; }

  /* ── CONTACT ── */
  .contact-section { background:#030712; padding:7rem 0; }

  /* Giant LET'S TALK */
  .contact-big { text-align:center; margin-bottom:5rem; overflow:hidden; }
  .lets-talk { font-family:'Plus Jakarta Sans',sans-serif; font-size:clamp(52px,10vw,140px); font-weight:800; letter-spacing:-0.04em; line-height:1; text-decoration:none; color:transparent; -webkit-text-stroke:1px rgba(201,169,110,0.3); display:inline-block; position:relative; transition:color 0.5s, -webkit-text-stroke 0.5s; background:linear-gradient(90deg,#C9A96E,#E8865A,#C9A96E); background-size:200%; -webkit-background-clip:text; background-clip:text; background-position:100% 0; }
  .lets-talk:hover { -webkit-text-stroke:0px transparent; -webkit-text-fill-color:transparent; background-position:0% 0; transition:background-position 0.6s ease, -webkit-text-stroke 0.3s; }

  .contact-grid { display:grid; grid-template-columns:1fr; gap:5rem; }
  @media(min-width:1024px) { .contact-grid { grid-template-columns:1fr 1fr; } }
  .contact-sub { font-size:14px; color:rgba(245,239,228,0.38); line-height:1.8; margin-bottom:3rem; }
  .contact-links { display:flex; flex-direction:column; gap:1.25rem; }
  .c-link { display:flex; align-items:center; gap:1.25rem; text-decoration:none; }
  .c-link-icon { width:3rem; height:3rem; border-radius:12px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .c-label { font-size:10px; letter-spacing:0.3em; text-transform:uppercase; color:rgba(245,239,228,0.48); margin-bottom:0.2rem; }
  .c-val   { font-size:14px; color:#F5EFE4; transition:color 0.2s; }
  .c-link:hover .c-val { color:#C9A96E; }
  .contact-right { background:#161310; border-radius:20px; padding:3rem; border:1px solid rgba(245,239,228,0.06); }
  .cf-row  { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
  .cf-input { display:block; width:100%; background:rgba(245,239,228,0.05); border:1px solid rgba(245,239,228,0.1); color:#F5EFE4; font-family:'DM Sans',sans-serif; font-size:14px; padding:14px 18px; border-radius:10px; outline:none; transition:border-color 0.3s; margin-bottom:1rem; }
  .cf-input::placeholder { color:rgba(245,239,228,0.25); }
  .cf-input:focus { border-color:rgba(201,169,110,0.5); }
  .cf-input option { background:#1C1814; }
  .cf-btn  { display:flex; align-items:center; justify-content:center; gap:12px; width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#030712; background:#C9A96E; padding:18px; border-radius:10px; border:none; cursor:none; transition:background 0.25s; position:relative; overflow:hidden; }
  .cf-btn:hover { background:#E2C98A; }
  .form-ok { font-size:13px; color:#5EC87A; text-align:center; margin-top:1rem; display:none; }


  /* ── PAYMENT MICRO-DEMO ── */
  .pay-demo { display:flex; flex-direction:column; gap:5px; margin:1rem 0 1.2rem; padding:0.9rem 1rem; background:rgba(0,0,0,0.2); border-radius:10px; border:1px solid rgba(240,122,74,0.15); }
  .pay-step { display:flex; align-items:center; gap:10px; font-size:11px; color:rgba(245,239,228,0.45); letter-spacing:0.04em; transition:color 0.35s, transform 0.35s; }
  .pay-icon { font-size:12px; opacity:0.35; transition:opacity 0.35s; flex-shrink:0; width:16px; text-align:center; }
  .pay-step.active { color:rgba(240,122,74,0.95); transform:translateX(3px); }
  .pay-step.active .pay-icon { opacity:1; }
  .pay-step.done { color:rgba(94,200,122,0.85); }
