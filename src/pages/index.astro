  @media(max-width:480px) { .hms-divider { display:none; } .hero-mini-stats { gap:1.4rem; } }

  .hero-bottom { display:flex; flex-direction:column; gap:2rem; padding-bottom:3rem; border-top:1px solid rgba(245,239,228,0.1); padding-top:2rem; opacity:0; } /* GSAP reveals */
  @media(min-width:768px) { .hero-bottom { flex-direction:row; align-items:center; justify-content:space-between; padding-bottom:4rem; } }
  .hero-bottom-left { display:flex; flex-direction:column; }
  .hero-sub  { font-size:14px; color:rgba(245,239,228,0.58); line-height:1.75; max-width:500px; }
  .hero-cta  { flex-shrink:0; display:inline-flex; align-items:center; gap:12px; font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#030712; background:#C9A96E; padding:18px 36px; text-decoration:none; border-radius:4px; transition:background 0.25s; white-space:nowrap; position:relative; overflow:hidden; }
  .hero-cta:hover { background:#E2C98A; }

  /* Magnetic sheen */
  .magnetic-btn::after { content:''; position:absolute; inset:0; background:linear-gradient(105deg,transparent 30%,rgba(255,255,255,0.18) 50%,transparent 70%); transform:translateX(-100%); transition:transform 0.5s ease; pointer-events:none; }
  .magnetic-btn:hover::after { transform:translateX(100%); }

  .hero-scroll { position:absolute; bottom:2rem; right:1.5rem; z-index:2; display:flex; flex-direction:column; align-items:center; gap:0.5rem; }
  @media(min-width:1024px) { .hero-scroll { right:5rem; } }
  .hero-scroll-line { width:1px; height:48px; background:linear-gradient(to bottom,rgba(201,169,110,0.8),transparent); animation:scrollLine 2s ease-in-out infinite; }
  .hero-scroll span { font-size:9px; letter-spacing:0.4em; text-transform:uppercase; color:rgba(245,239,228,0.25); }
  @keyframes scrollLine { 0%,100%{opacity:0.3;transform:scaleY(1)} 50%{opacity:1;transform:scaleY(1.2)} }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }

  /* ── MARQUEE (tilted + gradient + outlined alternating) ── */
  .marquee-wrap { overflow:hidden; background:#161310; padding:1.4rem 0; margin:1rem 0; border-top:1px solid rgba(245,239,228,0.06); border-bottom:1px solid rgba(245,239,228,0.06); }
  .marquee-track { display:flex; gap:2.5rem; width:max-content; animation:marquee 28s linear infinite; white-space:nowrap; }
  .marquee-track span { font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; background:linear-gradient(90deg,#C9A96E,#E8865A); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
  .marquee-outline { background:none !important; -webkit-text-fill-color:transparent !important; -webkit-text-stroke:1px rgba(201,169,110,0.45) !important; }
  .marquee-dot { background:linear-gradient(90deg,#C9A96E,#E8865A) !important; -webkit-background-clip:text !important; -webkit-text-fill-color:transparent !important; font-size:8px !important; }
  @keyframes marquee { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

  /* ── SERVICES (bento tilt cards) ── */
  .services-section { background:#030712; padding:7rem 0; }
