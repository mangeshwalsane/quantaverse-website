// 16. CONSTELLATION CURSOR TRAIL + CARD HALO
// ══════════════════════════════════════════
(function() {
  if (window.matchMedia('(hover:none)').matches) return;

  const canvas = document.getElementById('cursor-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;
  const GOLD   = 'rgba(201,169,110,';

  const MAX_LINK     = 90;    // trail link distance
  const MAX_LINK_HALO = 126;  // halo-to-halo link distance (×1.4)
  const MAX_AGE      = 2200;  // trail node lifetime ms
  const MAX_AGE_HALO = 3200;  // halo node lifetime ms — slower decay to sustain glow
  const SPAWN_DIST   = 12;    // px of travel before spawning trail node

  let W = 0, H = 0;
  function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  resize();
  window.addEventListener('resize', resize, { passive: true });

  interface TrailNode {
    x: number; y: number;
    vx: number; vy: number;
    born: number;
    r: number;
    isHalo: boolean;
    angle: number;   // orbital angle (halo only)
    speed: number;   // orbital speed (halo only)
  }

  const nodes: TrailNode[] = [];
  let lastX = -999, lastY = -999;
  let mouseX = 0, mouseY = 0;

  // Current halo target — set on card mouseenter, cleared on mouseleave
  let haloTarget: { x: number; y: number; w: number; h: number } | null = null;

  function spawnNode(x: number, y: number, isHalo: boolean) {
    const fast = isHalo;
    nodes.push({
      x, y,
      vx: (Math.random() - 0.5) * (fast ? 3 : 0.4),
      vy: (Math.random() - 0.5) * (fast ? 3 : 0.4) - (fast ? 0 : 0.15),
      born: performance.now(),
      r: fast ? 1.2 + Math.random() * 1.3 : 1.5 + Math.random() * 1.2,
      isHalo,
      angle: Math.random() * Math.PI * 2,
      speed: Math.random() * 0.5 + 0.2,
    });
  }

  // Track mouse — spawn trail nodes every SPAWN_DIST px
  window.addEventListener('mousemove', (e) => {
    mouseX = e.clientX; mouseY = e.clientY;
    const dx = mouseX - lastX, dy = mouseY - lastY;
    if (Math.sqrt(dx*dx + dy*dy) > SPAWN_DIST || lastX < 0) {
      spawnNode(mouseX, mouseY, haloTarget !== null);
      lastX = mouseX; lastY = mouseY;
    }
  }, { passive: true });

  // Wire halo to both .ind-card and .svc-card
  // Burst cooldown — prevents stacking when cursor slides across the gap:1px ind-grid boundary
  let lastBurstAt = 0;
  const BURST_COOLDOWN = 600; // ms

  document.querySelectorAll<HTMLElement>('.ind-card, .svc-card').forEach(card => {
    card.addEventListener('mouseenter', () => {
      const r = card.getBoundingClientRect();
      haloTarget = { x: r.left + r.width / 2, y: r.top + r.height / 2, w: r.width, h: r.height };

      // Only burst if enough time has passed since the last burst
      const now = performance.now();
      if (now - lastBurstAt > BURST_COOLDOWN) {
        lastBurstAt = now;
        for (let i = 0; i < 20; i++) {
          spawnNode(
            mouseX + (Math.random() - 0.5) * 30,
            mouseY + (Math.random() - 0.5) * 30,
            true
          );
        }
      }
    });
    card.addEventListener('mouseleave', () => {
      haloTarget = null;
      // Downgrade existing halo nodes to trail so they drift away naturally
      nodes.forEach(n => { n.isHalo = false; });
    });
    // Keep halo target rect fresh while scrolling inside a card (edge case)
    card.addEventListener('mousemove', () => {
      if (haloTarget) {
        const r = card.getBoundingClientRect();
        haloTarget = { x: r.left + r.width / 2, y: r.top + r.height / 2, w: r.width, h: r.height };
      }
    }, { passive: true });
  });

  function tick() {
    ctx.clearRect(0, 0, W, H);
    const now = performance.now();

    // Cull expired nodes (reverse iterate — O(1) splice from tail)
    for (let i = nodes.length - 1; i >= 0; i--) {
      const maxAge = nodes[i].isHalo ? MAX_AGE_HALO : MAX_AGE;
      if (now - nodes[i].born > maxAge) nodes.splice(i, 1);
    }

    // Draw connections first (rendered under dots)
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const ni = nodes[i], nj = nodes[j];
        const dx = ni.x - nj.x, dy = ni.y - nj.y;
        const d  = Math.sqrt(dx*dx + dy*dy);
        const maxLink = (ni.isHalo && nj.isHalo) ? MAX_LINK_HALO : MAX_LINK;
        if (d > maxLink) continue;

        const ageI = (now - ni.born) / (ni.isHalo ? MAX_AGE_HALO : MAX_AGE);
        const ageJ = (now - nj.born) / (nj.isHalo ? MAX_AGE_HALO : MAX_AGE);
        const proximity = 1 - d / maxLink;
        const alpha = proximity * (1 - Math.max(ageI, ageJ)) * (ni.isHalo && nj.isHalo ? 0.45 : 0.35);
        if (alpha <= 0) continue;

        ctx.beginPath();
        ctx.moveTo(ni.x, ni.y);
        ctx.lineTo(nj.x, nj.y);
        ctx.strokeStyle = GOLD + alpha + ')';
        ctx.lineWidth   = (ni.isHalo && nj.isHalo) ? 0.75 : 0.5;
        ctx.stroke();
      }
    }

    // Update physics + draw dots
    for (const n of nodes) {
      const maxAge = n.isHalo ? MAX_AGE_HALO : MAX_AGE;
      const age    = (now - n.born) / maxAge;

      if (n.isHalo && haloTarget) {
        // Orbital pull toward card perimeter
        n.angle += n.speed * 0.03;
        const tx = haloTarget.x + Math.cos(n.angle) * (haloTarget.w * 0.48);
        const ty = haloTarget.y + Math.sin(n.angle) * (haloTarget.h * 0.48);
        n.x += (tx - n.x) * 0.12;
        n.y += (ty - n.y) * 0.12;
      } else {
        // Standard drift
        n.x += n.vx;
        n.y += n.vy;
      }

      // Time-based alpha — frame-rate independent
      const fadeIn  = Math.min(age / 0.07, 1);
      const fadeOut = age > 0.6 ? 1 - (age - 0.6) / 0.4 : 1;
      const alpha   = fadeIn * fadeOut * (n.isHalo ? 0.8 : 0.9);
      if (alpha <= 0) continue;

      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r * fadeOut, 0, Math.PI * 2);
      ctx.fillStyle = GOLD + alpha + ')';
      ctx.fill();
    }

    requestAnimationFrame(tick);
  }
  tick();
})();

// ══════════════════════════════════════════
// 17. INDUSTRIES — diagonal matrix stagger + hover
// ══════════════════════════════════════════
(function() {
  const grid = document.getElementById('ind-grid');
  if (!grid) return;

  const cards = Array.from(grid.querySelectorAll<HTMLElement>('.ind-card'));
  const COLS  = 5; // logical grid columns (matches data-col max)

  // Diagonal stagger: cards on same diagonal (row+col) fire together
  ScrollTrigger.create({
    trigger: grid, start: 'top 78%', once: true,
    onEnter() {
      cards.forEach(card => {
        const row = parseInt(card.dataset.row || '0');
        const col = parseInt(card.dataset.col || '0');
        const diag = row + col;

        gsap.to(card, {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.65,
          delay: diag * 0.07,          // each diagonal wave 70ms apart
          ease: 'back.out(1.4)',
          clearProps: 'transform',     // hand off to CSS hover after
        });
      });
    }
  });

  // Hardware-accelerated hover: JS adds class, CSS handles translateY + shadow
  // Cursor glow tracking on each card
  cards.forEach(card => {
    card.addEventListener('mouseenter', () => card.classList.add('hovered'));
    card.addEventListener('mouseleave', () => card.classList.remove('hovered'));
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const r  = card.getBoundingClientRect();
      card.style.setProperty('--mx', ((e.clientX - r.left) / r.width  * 100) + '%');
      card.style.setProperty('--my', ((e.clientY - r.top)  / r.height * 100) + '%');
    });
  });
})();

// ══════════════════════════════════════════
// 16. CARD MICRO-INTERACTIONS
// ══════════════════════════════════════════

// ── 16a. Payment processing steps (card #02) ──
(function() {
  const payCard = document.getElementById('svc-payment-demo');
  if (!payCard) return;
  let running = false;

  function run() {
    if (running) return;
    running = true;
    const steps = payCard!.querySelectorAll<HTMLElement>('.pay-step');
    steps.forEach(s => s.classList.remove('active','done'));
    let i = 0;
    const next = () => {
      if (i < steps.length) {
        if (i > 0) steps[i-1].classList.add('done');
        steps[i].classList.add('active');
        i++;
        setTimeout(next, 620);
      } else {
        steps[steps.length-1].classList.add('done');
        setTimeout(() => { steps.forEach(s => s.classList.remove('active','done')); running = false; }, 1600);
      }
    };
    next();
  }

  new IntersectionObserver(e => { if (e[0].isIntersecting) run(); }, { threshold:0.5 }).observe(payCard);
  payCard.addEventListener('mouseenter', run);
})();

// ── 16b. Mobile app card — shimmer + tab switch + button tap ──
(function() {
  const card = document.getElementById('svc-mobile-demo');
  if (!card) return;

  const tabs = card.querySelectorAll<HTMLElement>('.md-tab');
  const rows = card.querySelectorAll<HTMLElement>('.md-row');
  const btn  = card.querySelector<HTMLElement>('.md-btn');
  let tabIdx = 0;

  function shimmerRows() {
    rows.forEach(r => r.classList.add('shimmer'));
    setTimeout(() => rows.forEach(r => r.classList.remove('shimmer')), 1200);
  }

  function nextTab() {
    tabs[tabIdx].classList.remove('md-tab-active');
    tabIdx = (tabIdx + 1) % tabs.length;
    tabs[tabIdx].classList.add('md-tab-active');
    shimmerRows();
  }

  function tapBtn() {
    btn?.classList.add('tap');
    setTimeout(() => btn?.classList.remove('tap'), 400);
  }

  // Auto-cycle on scroll into view
  let cycleTimer = 0;
  new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {
      shimmerRows();
      cycleTimer = window.setInterval(() => { nextTab(); }, 2200);
      setTimeout(tapBtn, 1200);
    } else {
      clearInterval(cycleTimer);
    }
  }, { threshold: 0.4 }).observe(card);

  // Manual cycle on hover
  card.closest('.svc-card')?.addEventListener('mouseenter', () => { nextTab(); tapBtn(); });
})();

// ── 16b2. Business website browser demo — page cycle ──
(function() {
  const demo = document.getElementById('svc-biz-demo');
  if (!demo) return;

  const pages = demo.querySelectorAll<HTMLElement>('.biz-page');
  const dots  = demo.querySelectorAll<HTMLElement>('.biz-pdot');
  let current = 0;
  let timer = 0;

  function goTo(idx: number) {
    pages[current].classList.remove('biz-page-active');
    dots[current].classList.remove('biz-pdot-active');
    current = idx % pages.length;
    pages[current].classList.add('biz-page-active');
    dots[current].classList.add('biz-pdot-active');
  }

  function next() { goTo(current + 1); }

  // Dot click navigation
  dots.forEach((dot, i) => dot.addEventListener('click', () => { goTo(i); clearInterval(timer); timer = window.setInterval(next, 2800); }));

  // Auto-cycle when scrolled into view
  new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {
      timer = window.setInterval(next, 2800);
    } else {
      clearInterval(timer);
    }
  }, { threshold: 0.4 }).observe(demo);

  // Speed up on card hover
  demo.closest('.svc-card')?.addEventListener('mouseenter', () => { clearInterval(timer); next(); timer = window.setInterval(next, 2200); });
  demo.closest('.svc-card')?.addEventListener('mouseleave', () => { clearInterval(timer); timer = window.setInterval(next, 2800); });
})();

// ── 16c. AI routing canvas + typing (card #04) ──
(function() {
  const wrap   = document.getElementById('svc-ai-demo');
  if (!wrap) return;
  const target = wrap.querySelector<HTMLElement>('.ai-type-text');
  const canvas = wrap.querySelector<HTMLCanvasElement>('.ai-canvas');
  if (!target || !canvas) return;

  // Typing animation
  const phrases = ['Classify support ticket...', 'Generate invoice PDF...', 'Summarise contract...', 'Route to correct queue...'];
  let pi = 0, typing = false, loopTimer = 0;

  function typeNext() {
    if (typing) return;
    typing = true;
    const phrase = phrases[pi % phrases.length];
    target.textContent = '';
    let ci = 0;
    const iv = setInterval(() => {
      target.textContent = phrase.slice(0, ++ci);
      if (ci >= phrase.length) {
        clearInterval(iv);
        loopTimer = window.setTimeout(() => { pi++; typing = false; typeNext(); }, 2000);
      }
    }, 50);
  }

  // Routing canvas — glowing dots travel from left (prompt) to right (nodes) via bezier paths
  const ctx = canvas.getContext('2d')!;

  interface RouteDot { t: number; speed: number; path: number; color: string; }
  const COLORS = ['#C47AE8','#6B8AE8','#3ECFB2','#E8865A'];
  const dots: RouteDot[] = [];
  let raf = 0;
  let W = 0, H = 0;

  // 3 destination nodes on the right
  const NODES = [0.22, 0.5, 0.78]; // y-fractions

  function resize() {
    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width  = Math.round(W * devicePixelRatio);
    canvas.height = Math.round(H * devicePixelRatio);
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }

  function spawnDot() {
    dots.push({
      t: 0,
      speed: 0.006 + Math.random() * 0.004,
      path: Math.floor(Math.random() * NODES.length),
      color: COLORS[Math.floor(Math.random() * COLORS.length)]
    });
  }

  function getBezier(t: number, pathIdx: number): [number, number] {
    const x0 = 12, y0 = H / 2;
    const x3 = W - 14, y3 = NODES[pathIdx] * H;
    const x1 = W * 0.38, y1 = y0;
    const x2 = W * 0.62, y2 = y3;
    const mt = 1 - t;
    const x = mt*mt*mt*x0 + 3*mt*mt*t*x1 + 3*mt*t*t*x2 + t*t*t*x3;
    const y = mt*mt*mt*y0 + 3*mt*mt*t*y1 + 3*mt*t*t*y2 + t*t*t*y3;
    return [x, y];
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Draw faint bezier track lines
    for (let pi2 = 0; pi2 < NODES.length; pi2++) {
      ctx.beginPath();
      ctx.moveTo(12, H / 2);
      const x3 = W - 14, y3 = NODES[pi2] * H;
      ctx.bezierCurveTo(W * 0.38, H / 2, W * 0.62, y3, x3, y3);
      ctx.strokeStyle = 'rgba(196,122,232,0.08)';
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Draw destination nodes
    NODES.forEach((ny, ni) => {
      const nx = W - 14, nny = ny * H;
      ctx.beginPath();
      ctx.arc(nx, nny, 4, 0, Math.PI * 2);
      ctx.fillStyle = COLORS[ni % COLORS.length];
      ctx.globalAlpha = 0.55;
      ctx.fill();
      ctx.globalAlpha = 1;
      // Label
      ctx.font = `bold ${Math.round(7 * devicePixelRatio) / devicePixelRatio}px DM Sans`;
      ctx.fillStyle = 'rgba(245,239,228,0.3)';
      ctx.fillText(['DB', 'API', 'AI'][ni], nx - 14, nny + 2.5);
    });

    // Source node (prompt)
    ctx.beginPath();
    ctx.arc(12, H / 2, 4, 0, Math.PI * 2);
    ctx.fillStyle = '#C47AE8';
    ctx.globalAlpha = 0.7;
    ctx.fill();
    ctx.globalAlpha = 1;

    // Move + draw dots
    for (let i = dots.length - 1; i >= 0; i--) {
      const d = dots[i];
      d.t += d.speed;
      if (d.t >= 1) { dots.splice(i, 1); continue; }
      const [x, y] = getBezier(d.t, d.path);
      // Glow
      const grad = ctx.createRadialGradient(x, y, 0, x, y, 5);
      grad.addColorStop(0, d.color);
      grad.addColorStop(1, 'transparent');
      ctx.beginPath();
      ctx.arc(x, y, 5, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.globalAlpha = 0.85 * (1 - Math.abs(d.t - 0.5) * 0.4);
      ctx.fill();
      ctx.globalAlpha = 1;

      // Bright centre
      ctx.beginPath();
      ctx.arc(x, y, 2, 0, Math.PI * 2);
      ctx.fillStyle = '#fff';
      ctx.globalAlpha = 0.7;
      ctx.fill();
      ctx.globalAlpha = 1;
    }

    raf = requestAnimationFrame(draw);
  }

  let spawnInterval = 0;

  function start() {
    resize();
    draw();
    spawnInterval = window.setInterval(spawnDot, 380);
    typeNext();
  }

  function stop() {
    cancelAnimationFrame(raf);
    clearInterval(spawnInterval);
    clearTimeout(loopTimer);
    typing = false;
  }

  new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) start(); else stop();
  }, { threshold: 0.35 }).observe(wrap);

  window.addEventListener('resize', () => { if (raf) { resize(); } }, { passive: true });
})();

// ── 16d. Easter egg — mouse-rotation of assembled formation ──
// Reads mouse position during easterActive and rotates the whole cluster
(function() {
  // Expose a hook into the particle system's mouse coords and easterActive flag
  // The particle canvas already tracks `mouse` — we add rotation in the tick loop
  // by patching the draw call. We do this by adding a module-level variable
  // that initParticles() reads after being defined.
  (window as any).__qvEasterRotEnabled = true;
})();
</script>

