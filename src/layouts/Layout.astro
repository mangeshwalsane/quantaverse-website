---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Quantaverse Labs — We design, build, and automate digital businesses.',
  description = 'Quantaverse Labs Pvt Ltd builds mobile apps, SaaS platforms, booking systems, AI tools, and custom digital infrastructure. Build once. Automate forever.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#1C1917" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>
  <div class="grain" aria-hidden="true"></div>
  <slot />
</body>
</html>
